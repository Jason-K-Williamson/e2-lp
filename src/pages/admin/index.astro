---
import { supabase, type PageVariant } from "../../lib/supabase";

const adminPass = import.meta.env.ADMIN_PASS;
const cookie = Astro.cookies.get("admin_auth");
const authed = cookie?.value === adminPass;

if (Astro.request.method === "POST") {
    const form = await Astro.request.formData();
    const pass = form.get("pass");
    if (pass === adminPass) {
        Astro.cookies.set("admin_auth", adminPass, {
            path: "/",
            httpOnly: true,
            maxAge: 60 * 60 * 8,
        });
        return Astro.redirect("/admin");
    }
}

const { data: variants } = authed
    ? await supabase
          .from("page_variants")
          .select("id,concept,tam,product_slug,hero_headline,active,created_at")
          .order("created_at", { ascending: false })
    : { data: [] };

const { data: products } = authed
    ? await supabase
          .from("products")
          .select("id,slug,name,description,active,created_at")
          .order("created_at", { ascending: true })
    : { data: [] };
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>e2 Admin</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <style>
            * { box-sizing: border-box; margin: 0; padding: 0; }
            body {
                font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
                background: #f4f5f7;
                color: #111;
                min-height: 100vh;
            }

            /* ── Header ──────────────────────────────── */
            .header {
                background: #0f0f0f;
                padding: 0 32px;
                height: 56px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                position: sticky;
                top: 0;
                z-index: 10;
            }
            .header-left { display: flex; align-items: center; gap: 20px; }
            .header h1 { font-size: 15px; font-weight: 700; color: #fff; }
            .header-tag {
                font-size: 10px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: #6366f1;
                background: rgba(99,102,241,.12);
                padding: 3px 8px;
                border-radius: 4px;
            }
            .header-actions { display: flex; gap: 10px; }
            .btn-primary {
                background: #6366f1;
                color: #fff;
                text-decoration: none;
                padding: 8px 16px;
                border-radius: 8px;
                font-size: 13px;
                font-weight: 600;
                transition: background 0.15s;
            }
            .btn-primary:hover { background: #4f46e5; }
            .btn-ghost {
                background: rgba(255,255,255,.08);
                color: #fff;
                text-decoration: none;
                padding: 8px 16px;
                border-radius: 8px;
                font-size: 13px;
                font-weight: 600;
                transition: background 0.15s;
            }
            .btn-ghost:hover { background: rgba(255,255,255,.16); }

            /* ── Layout ──────────────────────────────── */
            .page { max-width: 1100px; margin: 0 auto; padding: 32px 24px 80px; }

            /* ── Section headers ─────────────────────── */
            .section-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 14px;
            }
            .section-title {
                font-size: 11px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                color: #9ca3af;
            }
            .section-action {
                font-size: 12px;
                font-weight: 600;
                color: #6366f1;
                text-decoration: none;
                padding: 5px 12px;
                border: 1px solid #e0e0ff;
                background: #f5f5ff;
                border-radius: 7px;
                transition: all 0.15s;
            }
            .section-action:hover { background: #6366f1; color: #fff; border-color: #6366f1; }

            /* ── Products grid ───────────────────────── */
            .products-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                gap: 14px;
                margin-bottom: 40px;
            }
            .product-card {
                background: #fff;
                border: 1.5px solid #e5e7eb;
                border-radius: 14px;
                padding: 20px;
                position: relative;
                transition: border-color 0.15s, box-shadow 0.15s;
            }
            .product-card:hover {
                border-color: #c7d2fe;
                box-shadow: 0 2px 14px rgba(99,102,241,.08);
            }
            .product-card.active-product { border-color: #c7d2fe; }
            .product-card-top {
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                margin-bottom: 10px;
            }
            .product-name { font-size: 15px; font-weight: 700; color: #111; margin-bottom: 4px; }
            .product-slug {
                font-family: monospace;
                font-size: 11px;
                color: #9ca3af;
                background: #f3f4f6;
                padding: 2px 7px;
                border-radius: 5px;
                display: inline-block;
            }
            .product-desc {
                font-size: 12px;
                color: #6b7280;
                line-height: 1.55;
                margin: 10px 0 14px;
                display: -webkit-box;
                -webkit-line-clamp: 3;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }
            .product-footer {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding-top: 12px;
                border-top: 1px solid #f3f4f6;
            }
            .dot {
                display: inline-block;
                width: 7px;
                height: 7px;
                border-radius: 50%;
                margin-right: 5px;
            }
            .dot.on { background: #22c55e; }
            .dot.off { background: #d1d5db; }
            .status-text { font-size: 11px; font-weight: 600; color: #6b7280; }
            .edit-link {
                font-size: 12px;
                font-weight: 600;
                color: #6366f1;
                text-decoration: none;
            }
            .edit-link:hover { text-decoration: underline; }

            /* New product card (dashed) */
            .product-card-new {
                background: #fafafa;
                border: 1.5px dashed #d1d5db;
                border-radius: 14px;
                padding: 20px;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 8px;
                text-decoration: none;
                transition: all 0.15s;
                min-height: 152px;
            }
            .product-card-new:hover {
                border-color: #6366f1;
                background: #f5f5ff;
            }
            .product-card-new .plus { font-size: 28px; color: #d1d5db; line-height: 1; }
            .product-card-new:hover .plus { color: #6366f1; }
            .product-card-new span { font-size: 13px; font-weight: 600; color: #9ca3af; }
            .product-card-new:hover span { color: #6366f1; }

            /* ── Variants table ─────────────────────── */
            table {
                width: 100%;
                background: #fff;
                border: 1px solid #e5e7eb;
                border-radius: 14px;
                border-collapse: collapse;
                overflow: hidden;
            }
            th {
                text-align: left;
                padding: 11px 20px;
                font-size: 10px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                color: #9ca3af;
                border-bottom: 1px solid #e5e7eb;
                background: #f9fafb;
            }
            td {
                padding: 14px 20px;
                border-bottom: 1px solid #f3f4f6;
                font-size: 13px;
                vertical-align: middle;
            }
            tr:last-child td { border-bottom: none; }
            .url-pill {
                font-family: monospace;
                font-size: 11px;
                background: #f1f5f9;
                padding: 3px 8px;
                border-radius: 6px;
                color: #374151;
                display: inline-block;
            }
            .badge {
                display: inline-flex;
                align-items: center;
                gap: 4px;
                padding: 3px 9px;
                border-radius: 20px;
                font-size: 10px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.06em;
            }
            .badge.live { background: #dcfce7; color: #16a34a; }
            .badge.draft { background: #f1f5f9; color: #64748b; }
            .row-actions { display: flex; gap: 6px; }
            .row-actions a, .row-actions button {
                font-family: inherit;
                background: none;
                cursor: pointer;
                font-size: 11px;
                font-weight: 600;
                color: #6b7280;
                text-decoration: none;
                border: 1px solid #e5e7eb;
                padding: 4px 10px;
                border-radius: 6px;
                transition: all 0.15s;
            }
            .row-actions a:hover, .row-actions button:hover {
                background: #111;
                color: #fff;
                border-color: #111;
            }
            .row-actions button.delete-btn { color: #ef4444; }
            .row-actions button.delete-btn:hover {
                background: #ef4444;
                border-color: #ef4444;
                color: #fff;
            }
            .empty {
                text-align: center;
                padding: 60px 20px;
                color: #9ca3af;
            }

            /* ── Login ───────────────────────────────── */
            .login-wrap {
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                background: #0f0f0f;
            }
            .login-box {
                background: #1a1a1a;
                border: 1px solid #2a2a2a;
                border-radius: 16px;
                padding: 40px;
                width: 340px;
            }
            .login-box h1 { font-size: 20px; font-weight: 700; color: #fff; margin-bottom: 24px; }
            .login-box input {
                width: 100%;
                padding: 10px 14px;
                border: 1px solid #333;
                border-radius: 10px;
                font-size: 14px;
                outline: none;
                margin-bottom: 12px;
                background: #111;
                color: #fff;
            }
            .login-box button {
                width: 100%;
                padding: 11px;
                background: #6366f1;
                color: #fff;
                border: none;
                border-radius: 10px;
                font-size: 14px;
                font-weight: 600;
                cursor: pointer;
            }
            .login-box button:hover { background: #4f46e5; }
        </style>
    </head>
    <body>
        {!authed ? (
            <div class="login-wrap">
                <div class="login-box">
                    <h1>e2 Admin</h1>
                    <form method="POST">
                        <input type="password" name="pass" placeholder="Admin password" autofocus />
                        <button type="submit">Sign in</button>
                    </form>
                </div>
            </div>
        ) : (
            <>
                <div class="header">
                    <div class="header-left">
                        <h1>e2 Admin</h1>
                        <span class="header-tag">Internal</span>
                    </div>
                    <div class="header-actions">
                        <a href="/admin/new" class="btn-primary">+ New variant</a>
                    </div>
                </div>

                <div class="page">

                    {/* ── Products ───────────────────────────────────────── */}
                    <div class="section-header">
                        <span class="section-title">Products</span>
                        <a href="/admin/products/new" class="section-action">+ Add product</a>
                    </div>

                    <div class="products-grid">
                        {(products as any[] ?? []).map((p) => (
                            <div class={`product-card ${p.active ? "active-product" : ""}`}>
                                <div class="product-card-top">
                                    <div>
                                        <p class="product-name">{p.name}</p>
                                        <span class="product-slug">/{p.slug}</span>
                                    </div>
                                </div>
                                <p class="product-desc">{p.description || "No description added yet."}</p>
                                <div class="product-footer">
                                    <span class="status-text">
                                        <span class={`dot ${p.active ? "on" : "off"}`}></span>
                                        {p.active ? "Active" : "Inactive"}
                                    </span>
                                    <a href={`/admin/products/${p.id}`} class="edit-link">Edit description</a>
                                </div>
                            </div>
                        ))}

                        <a href="/admin/products/new" class="product-card-new">
                            <span class="plus">+</span>
                            <span>Add new product</span>
                        </a>
                    </div>

                    {/* ── Variants ───────────────────────────────────────── */}
                    <div class="section-header">
                        <span class="section-title">Landing page variants</span>
                        <a href="/admin/new" class="section-action">+ New variant</a>
                    </div>

                    {variants && variants.length > 0 ? (
                        <table>
                            <thead>
                                <tr>
                                    <th>URL</th>
                                    <th>Headline</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {(variants as any[]).map((v) => (
                                    <tr>
                                        <td>
                                            <span class="url-pill">
                                                /{v.product_slug ?? "flows"}/{v.concept}/{v.tam}
                                            </span>
                                        </td>
                                        <td style="max-width: 280px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #374151;">
                                            {v.hero_headline || <span style="color:#d1d5db;">No headline yet</span>}
                                        </td>
                                        <td>
                                            <span class={`badge ${v.active ? "live" : "draft"}`}>
                                                {v.active ? "Live" : "Draft"}
                                            </span>
                                        </td>
                                        <td style="color: #9ca3af; font-size: 12px;">
                                            {new Date(v.created_at).toLocaleDateString("en-AU", { day: "numeric", month: "short", year: "numeric" })}
                                        </td>
                                        <td>
                                            <div class="row-actions">
                                                <a href={`/${v.product_slug ?? "flows"}/${v.concept}/${v.tam}`} target="_blank">Preview</a>
                                                <a href={`/admin/${v.id}`}>Edit</a>
                                                <button class="delete-btn" data-id={v.id}>Delete</button>
                                            </div>
                                        </td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    ) : (
                        <div class="empty" style="background:#fff; border:1px solid #e5e7eb; border-radius:14px;">
                            <p style="font-size:28px; margin-bottom:10px;">✦</p>
                            <p style="font-size:15px; font-weight:600; margin-bottom:6px;">No variants yet</p>
                            <p style="font-size:13px;">Create your first concept-matched landing page.</p>
                        </div>
                    )}
                </div>

                <script define:vars={{ adminPass }}>
                    document.querySelectorAll('.delete-btn').forEach(btn => {
                        btn.addEventListener('click', async (e) => {
                            if (!confirm("Delete this variant?")) return;
                            const id = e.currentTarget.getAttribute('data-id');
                            const res = await fetch(`/api/variants/${id}`, {
                                method: 'DELETE',
                                headers: { 'x-admin-pass': adminPass }
                            });
                            if (res.ok) {
                                window.location.reload();
                            } else {
                                alert("Failed to delete variant");
                            }
                        });
                    });
                </script>
            </>
        )}
    </body>
</html>
