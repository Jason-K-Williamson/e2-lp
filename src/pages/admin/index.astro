---
import { supabase, type PageVariant } from "../../lib/supabase";

// Simple password gate
const adminPass = import.meta.env.ADMIN_PASS;
const cookie = Astro.cookies.get("admin_auth");
const authed = cookie?.value === adminPass;

if (Astro.request.method === "POST") {
    const form = await Astro.request.formData();
    const pass = form.get("pass");
    if (pass === adminPass) {
        Astro.cookies.set("admin_auth", adminPass, {
            path: "/",
            httpOnly: true,
            maxAge: 60 * 60 * 8,
        });
        return Astro.redirect("/admin");
    }
}

const { data: variants } = authed
    ? await supabase
          .from("page_variants")
          .select("id,concept,tam,hero_headline,active,created_at")
          .order("created_at", { ascending: false })
    : { data: [] };
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>e2 Admin — Page Variants</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            body {
                font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
                    sans-serif;
                background: #f9fafb;
                color: #111;
                min-height: 100vh;
            }
            .header {
                background: #fff;
                border-bottom: 1px solid #e5e7eb;
                padding: 16px 32px;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }
            .header h1 {
                font-size: 18px;
                font-weight: 700;
            }
            .header a {
                background: #111;
                color: #fff;
                text-decoration: none;
                padding: 9px 18px;
                border-radius: 8px;
                font-size: 13px;
                font-weight: 600;
            }
            .container {
                max-width: 900px;
                margin: 40px auto;
                padding: 0 24px;
            }
            table {
                width: 100%;
                background: #fff;
                border: 1px solid #e5e7eb;
                border-radius: 16px;
                border-collapse: collapse;
                overflow: hidden;
            }
            th {
                text-align: left;
                padding: 12px 20px;
                font-size: 11px;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.06em;
                color: #6b7280;
                border-bottom: 1px solid #e5e7eb;
                background: #f9fafb;
            }
            td {
                padding: 16px 20px;
                border-bottom: 1px solid #f3f4f6;
                font-size: 14px;
                vertical-align: middle;
            }
            tr:last-child td {
                border-bottom: none;
            }
            .url {
                font-family: monospace;
                font-size: 12px;
                background: #f3f4f6;
                padding: 3px 8px;
                border-radius: 6px;
                color: #374151;
            }
            .badge {
                display: inline-block;
                padding: 2px 10px;
                border-radius: 20px;
                font-size: 11px;
                font-weight: 600;
            }
            .badge.active {
                background: #dcfce7;
                color: #16a34a;
            }
            .badge.inactive {
                background: #f3f4f6;
                color: #6b7280;
            }
            .actions {
                display: flex;
                gap: 8px;
            }
            .actions a, .actions button {
                font-family: inherit;
                background: none;
                cursor: pointer;
                font-size: 12px;
                color: #6b7280;
                text-decoration: none;
                border: 1px solid #e5e7eb;
                padding: 5px 12px;
                border-radius: 6px;
                transition: all 0.15s;
            }
            .actions a:hover, .actions button:hover {
                background: #111;
                color: #fff;
                border-color: #111;
            }
            .actions button.delete-btn {
                color: #ef4444;
            }
            .actions button.delete-btn:hover {
                background: #ef4444;
                border-color: #ef4444;
                color: #fff;
            }
            .empty {
                text-align: center;
                padding: 60px 20px;
                color: #9ca3af;
            }
            .login-wrap {
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
            }
            .login-box {
                background: #fff;
                border: 1px solid #e5e7eb;
                border-radius: 16px;
                padding: 40px;
                width: 340px;
            }
            .login-box h1 {
                font-size: 20px;
                font-weight: 700;
                margin-bottom: 24px;
            }
            .login-box input {
                width: 100%;
                padding: 10px 14px;
                border: 1px solid #e5e7eb;
                border-radius: 10px;
                font-size: 14px;
                outline: none;
                margin-bottom: 12px;
            }
            .login-box button {
                width: 100%;
                padding: 11px;
                background: #111;
                color: #fff;
                border: none;
                border-radius: 10px;
                font-size: 14px;
                font-weight: 600;
                cursor: pointer;
            }
        </style>
    </head>
    <body>
        {
            !authed ? (
                <div class="login-wrap">
                    <div class="login-box">
                        <h1>🔐 e2 Admin</h1>
                        <form method="POST">
                            <input
                                type="password"
                                name="pass"
                                placeholder="Admin password"
                                autofocus
                            />
                            <button type="submit">Sign in</button>
                        </form>
                    </div>
                </div>
            ) : (
                <>
                    <div class="header">
                        <h1>⚡ Page Variants</h1>
                        <a href="/admin/new">+ New variant</a>
                    </div>
                    <div class="container">
                        {variants && variants.length > 0 ? (
                            <table>
                                <thead>
                                    <tr>
                                        <th>URL</th>
                                        <th>Headline</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th />
                                    </tr>
                                </thead>
                                <tbody>
                                    {(variants as any[]).map((v) => (
                                        <tr>
                                            <td>
                                                <span class="url">
                                                    /{v.concept}/{v.tam}
                                                </span>
                                            </td>
                                            <td style="max-width: 260px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #374151;">
                                                {v.hero_headline}
                                            </td>
                                            <td>
                                                <span
                                                    class={`badge ${
                                                        v.active
                                                            ? "active"
                                                            : "inactive"
                                                    }`}
                                                >
                                                    {v.active
                                                        ? "Live"
                                                        : "Draft"}
                                                </span>
                                            </td>
                                            <td style="color: #9ca3af; font-size: 12px;">
                                                {new Date(
                                                    v.created_at
                                                ).toLocaleDateString()}
                                            </td>
                                            <td>
                                                <div class="actions">
                                                    <a
                                                        href={`/${v.concept}/${v.tam}`}
                                                        target="_blank"
                                                    >
                                                        Preview ↗
                                                    </a>
                                                    <a href={`/admin/${v.id}`}>
                                                        Edit
                                                    </a>
                                                    <button class="delete-btn" data-id={v.id}>
                                                        Delete
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    ))}
                                </tbody>
                            </table>
                        ) : (
                            <div class="empty">
                                <p style="font-size: 32px; margin-bottom: 12px;">
                                    ✦
                                </p>
                                <p style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">
                                    No variants yet
                                </p>
                                <p>
                                    Create your first concept-matched landing
                                    page.
                                </p>
                            </div>
                        )}
                    </div>
                </>
            )
        }
        {
            authed && (
                <script define:vars={{ adminPass }}>
                    document.querySelectorAll('.delete-btn').forEach(btn => {
                        btn.addEventListener('click', async (e) => {
                            if (!confirm("Are you sure you want to delete this variant?")) return;
                            const id = e.target.getAttribute('data-id');
                            const res = await fetch(`/api/variants/${id}`, {
                                method: 'DELETE',
                                headers: { 'x-admin-pass': adminPass }
                            });
                            if (res.ok) {
                                window.location.reload();
                            } else {
                                alert("Failed to delete variant");
                            }
                        });
                    });
                </script>
            )
        }
    </body>
</html>
