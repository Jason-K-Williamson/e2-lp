---
import { supabase } from "../../../lib/supabase";

const adminPass = import.meta.env.ADMIN_PASS;
const cookie = Astro.cookies.get("admin_auth");
if (cookie?.value !== adminPass) return Astro.redirect("/admin");

if (Astro.request.method === "POST") {
    const form = await Astro.request.formData();
    const slug = ((form.get("slug") as string) ?? "")
        .toLowerCase()
        .replace(/[^a-z0-9-]/g, "");
    const name = (form.get("name") as string) ?? "";
    const description = (form.get("description") as string) ?? "";

    const { error } = await supabase
        .from("products")
        .insert({ slug, name, description });

    if (!error) return Astro.redirect("/admin");
    // fall through and re-render with an error visible in the console
    console.error("Product insert error:", error.message, error.details);
}
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>New Product — e2 Admin</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            body {
                font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
                    sans-serif;
                background: #f9fafb;
                color: #111;
                min-height: 100vh;
            }
            .header {
                background: #fff;
                border-bottom: 1px solid #e5e7eb;
                padding: 16px 32px;
                display: flex;
                align-items: center;
                gap: 16px;
            }
            .header a {
                font-size: 13px;
                color: #6b7280;
                text-decoration: none;
            }
            .header a:hover {
                color: #111;
            }
            .header h1 {
                font-size: 18px;
                font-weight: 700;
            }
            .container {
                max-width: 720px;
                margin: 40px auto;
                padding: 0 24px;
            }
            .card {
                background: #fff;
                border: 1px solid #e5e7eb;
                border-radius: 16px;
                padding: 32px;
            }
            label {
                display: block;
                font-size: 11px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.09em;
                color: #9ca3af;
                margin-bottom: 6px;
            }
            .hint {
                font-size: 12px;
                color: #c4c9d4;
                margin-bottom: 8px;
            }
            input,
            textarea {
                width: 100%;
                padding: 10px 14px;
                border: 1px solid #e5e7eb;
                border-radius: 10px;
                font-size: 14px;
                font-family: inherit;
                outline: none;
                background: #fafafa;
                color: #111;
                transition: border-color 0.15s;
            }
            input::placeholder,
            textarea::placeholder {
                opacity: 0.35;
            }
            input:focus,
            textarea:focus {
                border-color: #6366f1;
                background: #fff;
            }
            textarea {
                resize: vertical;
                line-height: 1.6;
            }
            .field {
                margin-bottom: 20px;
            }
            .actions {
                display: flex;
                gap: 12px;
                margin-top: 24px;
                align-items: center;
            }
            .btn {
                padding: 12px 28px;
                background: #111;
                color: #fff;
                border: none;
                border-radius: 10px;
                font-size: 14px;
                font-weight: 700;
                cursor: pointer;
                font-family: inherit;
            }
            .btn:hover {
                background: #222;
            }
            .cancel {
                font-size: 13px;
                color: #9ca3af;
                text-decoration: none;
            }
        </style>
    </head>
    <body>
        <div class="header">
            <a href="/admin/products">← Products</a>
            <h1>New Product</h1>
        </div>
        <div class="container">
            <div class="card">
                <form method="POST">
                    <div class="field">
                        <label>Slug</label>
                        <p class="hint">
                            URL-safe identifier. Becomes the first segment in
                            /[slug]/[concept]/[tam].
                        </p>
                        <input
                            type="text"
                            name="slug"
                            placeholder="flows"
                            required
                            pattern="[a-z0-9-]+"
                        />
                    </div>
                    <div class="field">
                        <label>Product Name</label>
                        <input
                            type="text"
                            name="name"
                            placeholder="Email Flow Buildout"
                            required
                        />
                    </div>
                    <div class="field">
                        <label>Description</label>
                        <p class="hint">
                            Describe what this product is, what you deliver,
                            what makes it different, price structure, timelines,
                            who it's for. The AI reads this verbatim before
                            generating any copy for this product.
                        </p>
                        <textarea
                            name="description"
                            rows={12}
                            placeholder="Write everything the AI needs to know about this product. What is it? What do we deliver? What's included? How are we different from agency retainers? What's the price model? How long does it take? What's the outcome? Be specific and honest."
                            required></textarea>
                    </div>
                    <div class="actions">
                        <button type="submit" class="btn">Create product</button
                        >
                        <a href="/admin/products" class="cancel">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </body>
</html>
