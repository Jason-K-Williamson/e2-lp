---
import { supabase, type PageVariant } from "../../lib/supabase";
import VariantEditor from "../../components/admin/VariantEditor";

const adminPass = import.meta.env.ADMIN_PASS;
const cookie = Astro.cookies.get("admin_auth");
if (cookie?.value !== adminPass) {
    return Astro.redirect("/admin");
}

const { id } = Astro.params;
const { data, error } = await supabase
    .from("page_variants")
    .select("*")
    .eq("id", id)
    .single();

if (error || !data) {
    return Astro.redirect("/admin");
}

const variant = data as PageVariant;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Edit /{variant.concept}/{variant.tam} — e2 Admin</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            body {
                font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
                    sans-serif;
                background: #f9fafb;
                color: #111;
                min-height: 100vh;
            }
        </style>
    </head>
    <body>
        <VariantEditor variant={variant} adminPass={adminPass} client:load />
    </body>
</html>
