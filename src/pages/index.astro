---
import BaseLayout from "../layouts/BaseLayout.astro";
import StickyNav from "../components/StickyNav.astro";
import Hero from "../components/Hero.astro";
import SocialProof from "../components/SocialProof.astro";
import MajorCaseStudies from "../components/MajorCaseStudies.astro";
import EmailGallery from "../components/EmailGallery.astro";
import MinorCaseStudies from "../components/MinorCaseStudies.astro";
import Testimonials from "../components/Testimonials.astro";
import HeroTestimonial from "../components/HeroTestimonial.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
import FormflowModal from "../components/FormflowModal.astro";
import { supabase, DEFAULT_VARIANT } from "../lib/supabase";

const isAdmin = !!(Astro.locals as any).isAdmin;

// ── Resolve variant row: always read from DB when possible ───────────────────
// This is what powers the visual editor round-trip: we save via PUT /api/variants/:id
// and read back here on every page render so edits persist after refresh.
let defaultVariantId: string | undefined;
let variant = DEFAULT_VARIANT;

// Look for the canonical default row (works for both admin and regular visitors)
const { data: existing } = await supabase
     .from("page_variants")
     .select("*")
     .eq("concept", "default")
     .eq("tam", "homepage")
     .maybeSingle();

if (existing) {
     defaultVariantId = existing.id;
     // Merge saved fields over defaults so any undefined/missing keys still have a value
     variant = { ...DEFAULT_VARIANT, ...existing };
} else if (isAdmin) {
     // First admin visit — seed the row from DEFAULT_VARIANT so saves work later
     const { data: seeded } = await supabase
          .from("page_variants")
          .insert({
               concept: "default",
               tam: "homepage",
               active: true,
               ...DEFAULT_VARIANT,
          })
          .select("*")
          .single();
     if (seeded) {
          defaultVariantId = seeded.id;
          variant = { ...DEFAULT_VARIANT, ...seeded };
     }
}

const title = "Real Results. Real Brands. Real Revenue. | e2 Agency";
const description =
     "$225M+ generated. 2,000+ brands. See the case studies, designs, and client results that prove it.";
---

<BaseLayout
     title={title}
     description={description}
     variantId={defaultVariantId}
>
     <!-- Formflow modal overlay — opened by any href="#qualify" click -->
     <FormflowModal />

     <!-- Sticky pill nav -->
     <StickyNav />

     <!-- 1. HERO — VSL + logo bar -->
     <Hero
          badge={variant.hero_badge}
          headline={variant.hero_headline}
          subheadline={variant.hero_subheadline}
          ctaPrimary={variant.hero_cta_primary}
          ctaSecondary={variant.hero_cta_secondary}
     />

     <!-- 2. PROOF BAR — $225M + 4 supporting stats -->
     <SocialProof />

     <!-- 3. HERO TESTIMONIAL — Davie Fogarty / The Oodie -->
     <HeroTestimonial />

     <!-- 4. MAJOR CASE STUDIES — 5 full-width hero studies with video testimonials -->
     <MajorCaseStudies />

     <!-- 5. DESIGNS — Email scroll gallery + Figma showcase -->
     <EmailGallery />

     <!-- 6. MINOR CASE STUDIES — BFCM + supporting grid -->
     <MinorCaseStudies />

     <!-- 7. TESTIMONIALS — Wall of Love -->
     <Testimonials />

     <!-- 8. FINAL CTA — Form embed section -->
     <FinalCTA
          heading={variant.finalcta_heading}
          subheading={variant.finalcta_subheading}
     />

     <!-- 9. FOOTER -->
     <Footer />
</BaseLayout>
