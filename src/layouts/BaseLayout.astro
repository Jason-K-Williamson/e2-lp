---
import VisualEditor from "../components/VisualEditor.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  variantId?: string;
}

const {
  title,
  description,
  ogImage = "/og-default.jpg",
  variantId,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const isAdmin = !!(Astro.locals as any).isAdmin;
const adminPass = isAdmin ? import.meta.env.ADMIN_PASS : "";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!--
      PERFORMANCE: Self-hosted fonts — zero external DNS lookups.
      Preload only the critical display weight (Syne 800 for hero headline).
      DM Sans loads via @font-face in CSS with font-display:swap — no FOIT.
    -->
    <link
      rel="preload"
      href="/fonts/DMSans-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/DMSans-500.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/DMSans-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body
    class="min-h-screen overflow-x-hidden"
    data-variant-id={variantId ?? ""}
  >
    <main>
      <slot />
    </main>

    {
      isAdmin && (
        <VisualEditor variantId={variantId ?? ""} adminPass={adminPass} />
      )
    }

    <!--
      GSAP: Astro processes this import at build time.
      Tree-shakes to only ScrollTrigger + core.
      Deferred by browser since it's a module script.
    -->
    <script>
      // Fallback: reveal content if GSAP never fires (in < 3s)
      (function () {
        var t = setTimeout(function () {
          document.querySelectorAll("[data-animate]").forEach(function (el) {
            (el as HTMLElement).style.opacity = "1";
            (el as HTMLElement).style.transform = "none";
          });
        }, 3000);
        (window as any).__gsapFallbackTimer = t;
      })();
    </script>
    <script>
      try {
        const { gsap } = await import("gsap");
        const { ScrollTrigger } = await import("gsap/ScrollTrigger");

        gsap.registerPlugin(ScrollTrigger);

        // Cancel fallback timer — GSAP loaded fine
        if ((window as any).__gsapFallbackTimer)
          clearTimeout((window as any).__gsapFallbackTimer);

        // ── Fix: fire immediately if DOMContentLoaded already fired ──────────
        const runAnimations = () => {
          const elements = document.querySelectorAll("[data-animate]");
          elements.forEach((el, i) => {
            gsap.to(el, {
              opacity: 1,
              y: 0,
              duration: 0.9,
              delay: i * 0.08,
              ease: "expo.out",
              force3D: true,
              scrollTrigger: {
                trigger: el,
                start: "top 90%",
                toggleActions: "play none none none",
              },
            });
          });

          const orbs = document.querySelectorAll("[data-parallax]");
          orbs.forEach((orb) => {
            const speed = parseFloat(
              (orb as HTMLElement).dataset.parallax || "0.5"
            );
            gsap.to(orb, {
              y: () => window.innerHeight * speed * -0.3,
              ease: "none",
              scrollTrigger: {
                trigger: orb,
                start: "top bottom",
                end: "bottom top",
                scrub: 1,
              },
            });
          });

          const counters = document.querySelectorAll("[data-counter]");
          counters.forEach((counter) => {
            const target = (counter as HTMLElement).dataset.counter || "";
            const el = counter as HTMLElement;
            ScrollTrigger.create({
              trigger: el,
              start: "top 85%",
              once: true,
              onEnter: () => {
                const prefix = target.match(/^[^0-9]*/)?.[0] || "";
                const suffix = target.match(/[^0-9]*$/)?.[0] || "";
                const num = parseFloat(target.replace(/[^0-9.]/g, ""));
                if (isNaN(num)) {
                  el.textContent = target;
                  return;
                }
                const obj = { val: 0 };
                gsap.to(obj, {
                  val: num,
                  duration: 1.8,
                  ease: "power2.out",
                  onUpdate: () => {
                    el.textContent =
                      prefix +
                      (num >= 100 ? Math.round(obj.val) : obj.val.toFixed(0)) +
                      suffix;
                  },
                  onComplete: () => {
                    el.textContent = target;
                  },
                });
              },
            });
          });
        };

        // Yield to browser first paint, then register animations
        // requestIdleCallback is safe here — GSAP uses ScrollTrigger so
        // animations only play once elements enter the viewport anyway.
        const scheduleAnimations = () => {
          if ("requestIdleCallback" in window) {
            (window as any).requestIdleCallback(runAnimations, {
              timeout: 1000,
            });
          } else {
            setTimeout(runAnimations, 0);
          }
        };

        // Fire immediately if DOM already ready, else wait
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", scheduleAnimations);
        } else {
          scheduleAnimations();
        }
      } catch (e) {
        // GSAP blocked (e.g. Cloudflare SES lockdown) — reveal all content immediately
        document.querySelectorAll("[data-animate]").forEach((el) => {
          (el as HTMLElement).style.opacity = "1";
          (el as HTMLElement).style.transform = "none";
        });
      }
    </script>
  </body>
</html>
