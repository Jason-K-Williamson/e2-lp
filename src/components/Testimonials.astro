---
/**
 * Testimonials , Wall of Love
 * Per 2026 playbook: before→after metric format, photos, specific metrics
 * Davie Fogarty now lives in CaseStudies , this is the supporting wall
 */
const testimonials = [
  {
    quote: "E2 agency is by far the best agency we've worked with as a multi 7 figure brand. They added 30–40% to our top line revenue. If you want results like that, you need to go with E2.",
    author: "Colin",
    role: "Owner/CEO",
    company: "Fleecies · Fashion & Apparel",
    before: "~20%",
    after: "~40%+",
    metricLabel: "Email % of total revenue",
  },
  {
    quote: "Within our first month, our attributed revenue from Klaviyo went from 5% to 32%. After 3 months it's now 40%. Communication couldn't be quicker, organisation is top notch and the design is 10/10!",
    author: "Gemma Elliott",
    role: "Owner/Founder",
    company: "Luscious Living Co",
    before: "5%",
    after: "40%",
    metricLabel: "Klaviyo attributed revenue",
  },
  {
    quote: "Our revenue from campaigns grew 3x while e2 was in charge. Irina's professionalism and creative approach never ceased to please me. Absolute pleasure to work with.",
    author: "Marina Kalenchyts",
    role: "Brand Director",
    company: "Wonderskin",
    before: "1x",
    after: "3x",
    metricLabel: "Campaign revenue",
  },
  {
    quote: "We've more than tripled our email optin rate and gotten a ton of SMS optins. Jason knows Klaviyo and ecommerce email marketing inside out. No matter if you're doing $50k or $1M+ per month — hire him, you won't be disappointed.",
    author: "Dima Kritchevski",
    role: "Brand Owner",
    company: "DTC Brand",
    before: "1x",
    after: "3x+",
    metricLabel: "Email opt-in rate",
  },
  {
    quote: "He made one simple suggestion in our call which we did — and in one day we went from an open rate of 5% to 14%. Jason knows his stuff. Our hour with Jason was a game-changer.",
    author: "Steph",
    role: "Operations Manager",
    company: "Little Label Co",
    before: "5%",
    after: "14%",
    metricLabel: "Email open rate",
  },
  {
    quote: "Jason thinks outside of the box, which sets him apart from everyone else. He didn't just hand over a blueprint — he remained fully invested in the implementation every step of the way.",
    author: "Gary",
    role: "Manager",
    company: "Brand House Direct",
    before: "Low",
    after: "Growing",
    metricLabel: "Open rates, CTR & deliverability",
  },
  {
    quote: "The list existed. The revenue didn't. We built their first campaign system, ran BFCM weekend, and the list did exactly what a list is supposed to do.",
    author: "e2 Agency",
    role: "Verified via Klaviyo",
    company: "Nursery Near Me · Home & Garden eCommerce",
    before: "$0",
    after: "$44k",
    metricLabel: "BFCM campaign revenue · dormant list",
  },
];
---

<section class="py-32 relative">
  <div class="section-container">

    <div class="max-w-3xl mx-auto text-center mb-16">
      <p class="text-xs font-bold uppercase tracking-widest text-blue-600 mb-4">Client Results</p>
      <h2 class="font-bold text-4xl md:text-5xl text-e2-black tracking-tight mb-4 text-balance">
        750+ Build-Outs.<br/>
        <span class="text-gray-400">Here's What Happened.</span>
      </h2>
    </div>

    <!-- Masonry grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        testimonials.map((t) => (
          <div class="glass-panel p-8 rounded-[2rem] hover:bg-white hover:shadow-xl hover:shadow-gray-100/50 transition-all duration-300 group flex flex-col">

            <!-- Before → After metric -->
            <div class="flex items-center gap-3 mb-6">
              <div class="flex-1 text-center">
                <div class="text-xl font-black text-gray-400 tracking-tight">{t.before}</div>
                <div class="text-[9px] text-gray-400 font-bold uppercase tracking-widest">Before</div>
              </div>
              <svg class="w-8 h-8 text-blue-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
              <div class="flex-1 text-center">
                <div class="text-2xl font-black text-e2-black tracking-tight">{t.after}</div>
                <div class="text-[9px] text-gray-500 font-bold uppercase tracking-widest">After</div>
              </div>
            </div>

            <p class="text-[10px] text-blue-600 font-bold uppercase tracking-widest mb-4">{t.metricLabel}</p>

            <blockquote class="text-gray-600 leading-relaxed mb-6 flex-1 text-sm">
              "{t.quote}"
            </blockquote>

            <div class="flex items-center gap-3 mt-auto pt-4 border-t border-gray-100">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-gray-200 to-gray-300 flex items-center justify-center text-sm font-black text-gray-600 flex-shrink-0">
                {t.author.charAt(0)}
              </div>
              <div class="text-sm min-w-0">
                <span class="font-bold text-e2-black block">{t.author}</span>
                <span class="text-gray-400 text-xs truncate block">{t.role}, {t.company}</span>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Aggregate trust metric -->
    <div class="mt-12 text-center">
      <p class="text-sm text-gray-400">
        Based on <strong class="text-e2-black">750+</strong> flow builds across eCom brands in AU, NZ, UK &amp; USA.
        Average client email contribution to revenue <strong class="text-e2-black">increases 31%</strong> within 90 days.
      </p>
    </div>

  </div>
</section>
