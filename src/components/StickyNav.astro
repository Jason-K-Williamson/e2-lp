---
/**
 * Sticky Nav , "Glass Pill"
 * Per 2026 playbook: sticky CTA bar following scroll, cold-traffic temperature copy
 * CTA links to #qualify (GetFormFlow form anchor)
 */
---

<div
  id="sticky-nav"
  class="fixed bottom-8 left-1/2 -translate-x-1/2 z-50 transition-all duration-500 opacity-0 translate-y-10"
>
  <div
    class="glass pl-6 pr-2 py-2 rounded-full flex items-center gap-5 shadow-2xl shadow-black/15 border border-white/60"
  >
    <!-- Social proof pill -->
    <div class="hidden sm:flex items-center gap-2">
      <span class="relative flex h-2 w-2">
        <span
          class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"
          style="will-change: transform;"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"
        ></span>
      </span>
      <span class="text-xs font-semibold text-gray-700"
        >2 spots left this month</span
      >
    </div>

    <!-- Separator -->
    <div class="hidden sm:block w-px h-4 bg-gray-200"></div>

    <!-- CTA -->
    <a
      href="#qualify"
      class="px-6 py-2.5 bg-e2-black text-white text-sm font-bold rounded-full hover:bg-gray-900 transition-colors duration-200 whitespace-nowrap"
    >
      See If You Qualify →
    </a>
  </div>
</div>

<script>
  const nav = document.getElementById("sticky-nav");
  const qualify = document.getElementById("qualify");

  if (nav) {
    let qualifyVisible = false;

    if (qualify) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          qualifyVisible = entry.isIntersecting;
          if (qualifyVisible) {
            nav.classList.add("opacity-0", "translate-y-10");
          } else if (window.scrollY > 500) {
            nav.classList.remove("opacity-0", "translate-y-10");
          }
        },
        { threshold: 0.05 }
      );
      observer.observe(qualify);
    }

    window.addEventListener(
      "scroll",
      () => {
        if (qualifyVisible) return;
        if (window.scrollY > 500) {
          nav.classList.remove("opacity-0", "translate-y-10");
        } else {
          nav.classList.add("opacity-0", "translate-y-10");
        }
      },
      { passive: true }
    );
  }
</script>
