---
/**
 * Social Proof Strip — Credibility anchor immediately below Hero
 * Per 2026 playbook: 4-5 hard metrics, DocSend-style stat bar
 * "Earns the right" for every claim that follows
 */
const supporting = [
  { value: "2,000+", label: "Brands Helped" },
  { value: "750+", label: "Active Retainers" },
  { value: "21 Days", label: "Avg. Flows Live" },
  { value: "31%+", label: "Avg. Klaviyo Revenue Increase" },
];
---

<section class="py-14 relative z-10 border-y border-gray-100/80">
  <div class="section-container">
    <!-- Featured revenue number (too long for a 5-col grid) -->
    <div class="text-center mb-10">
      <div
        class="font-black text-5xl md:text-6xl text-e2-black tracking-tight tabular-nums mb-2"
      >
        $225,669,414
      </div>
      <div
        class="text-xs text-gray-400 font-semibold uppercase tracking-widest"
      >
        Revenue Generated for Clients
      </div>
    </div>

    <!-- 4 supporting stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 border-t border-gray-100 pt-8">
      {
        supporting.map((stat, i) => (
          <div
            class={`text-center px-6 py-2 ${
              i !== 0 ? "border-l border-gray-100" : ""
            }`}
          >
            <div class="font-black text-3xl md:text-4xl text-e2-black tracking-tight tabular-nums mb-1">
              {stat.value}
            </div>
            <div class="text-xs text-gray-400 font-semibold uppercase tracking-wider whitespace-nowrap">
              {stat.label}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
