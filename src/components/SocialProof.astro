---
const stats = [
  { value: "$200M+", label: "Generated" },
  { value: "750+", label: "Flows Built" },
  { value: "12x", label: "Avg. ROI" },
  { value: "48hr", label: "Turnaround" },
];
---

<section class="py-12 relative z-10">
  <div class="section-container">
    <div
      class="glass-panel rounded-3xl p-8 md:p-12 flex flex-wrap md:flex-nowrap items-center justify-between gap-8 md:gap-0"
    >
      {
        stats.map((stat, i) => (
          <div
            class={`text-center flex-1 ${i !== 0 ? "md:border-l md:border-gray-100" : ""}`}
          >
            <div class="block font-bold text-4xl md:text-5xl text-e2-black tracking-tight mb-1">
              {stat.value}
            </div>
            <div class="text-xs text-gray-400 font-semibold uppercase tracking-wider">
              {stat.label}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
