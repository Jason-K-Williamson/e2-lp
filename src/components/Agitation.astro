---
import { DEFAULT_VARIANT } from "../lib/supabase";

interface Props {
  heading?: string;
  subheading?: string;
  agitationBody?: string;
  stakesBody?: string;
}

const {
  agitationBody = DEFAULT_VARIANT.prob_agitation_body,
  stakesBody = DEFAULT_VARIANT.prob_stakes_body,
} = Astro.props;

const isAdmin = !!(Astro.locals as any).isAdmin;

const editProps = (field: string) =>
  isAdmin
    ? {
        contenteditable: "false",
        "data-field": field,
        spellcheck: false as const,
      }
    : {};
---

<!-- ===== COST OF INACTION ===== -->
<section
  id="cost-of-inaction"
  class="h-[100svh] min-h-[600px] relative overflow-hidden bg-white flex items-center"
>
  <!-- Subtle top/bottom gradient -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-gray-50/0 via-red-50/20 to-gray-50/0 pointer-events-none"
  >
  </div>

  <div class="section-container relative z-10 max-w-3xl mx-auto">
    <!-- Section label -->
    <div class="text-center mb-10">
      <span
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-50 border border-red-100 text-red-500 text-xs font-bold uppercase tracking-widest"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse"></span>
        The Cost of Inaction
      </span>
    </div>

    <!-- Agitation paragraph -->
    <p
      class="text-xl md:text-2xl text-gray-700 leading-relaxed text-center mb-12 text-balance font-medium"
      {...editProps("prob_agitation_body")}
    >
      {agitationBody}
    </p>

    <!-- Stakes card -->
    <div
      class="rounded-3xl border border-red-100 bg-red-50/60 p-8 md:p-10 flex gap-6 items-start shadow-sm"
    >
      <div
        class="w-12 h-12 rounded-2xl bg-white border border-red-100 shadow-sm flex items-center justify-center text-2xl shrink-0"
      >
        ⏳
      </div>
      <div>
        <h3 class="font-bold text-xl text-gray-900 mb-3">
          The Cost of Waiting
        </h3>
        <p
          class="text-gray-600 leading-relaxed"
          {...editProps("prob_stakes_body")}
        >
          {stakesBody}
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ===== THE SOLUTION ===== -->
<section
  id="solution"
  class="h-[100svh] min-h-[700px] relative overflow-hidden bg-e2-black flex items-center"
>
  <!-- Ambient glow -->
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] bg-blue-600/10 rounded-full blur-[120px] pointer-events-none"
  >
  </div>

  <div class="section-container relative z-10 max-w-4xl mx-auto w-full">
    <!-- Section label -->
    <div class="text-center mb-10">
      <span
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-xs font-bold uppercase tracking-widest"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span>
        The Solution
      </span>
    </div>

    <h2
      class="text-4xl md:text-5xl font-black text-white tracking-tight text-center mb-6 leading-tight text-balance"
    >
      Full Send Email and SMS
    </h2>

    <p
      class="text-xl text-gray-400 leading-relaxed text-center max-w-2xl mx-auto mb-14"
    >
      A complete done-for-you build for DTC brands. Six flows, an SMS channel,
      senior copywriters, design, and full Klaviyo setup. Built once. Runs
      forever. You own every asset on day one.
    </p>

    <!-- Stats grid -->
    <div class="grid grid-cols-3 gap-4 md:gap-6 max-w-2xl mx-auto mb-14">
      <div
        class="rounded-2xl bg-white/5 border border-white/10 p-5 md:p-6 text-center"
      >
        <div class="text-4xl font-black text-white mb-1">21</div>
        <div class="text-xs text-gray-500 uppercase tracking-widest font-bold">
          Day build
        </div>
      </div>
      <div
        class="rounded-2xl bg-white/5 border border-white/10 p-5 md:p-6 text-center"
      >
        <div class="text-4xl font-black text-white mb-1">90</div>
        <div class="text-xs text-gray-500 uppercase tracking-widest font-bold">
          Day results
        </div>
      </div>
      <div
        class="rounded-2xl bg-white/5 border border-white/10 p-5 md:p-6 text-center"
      >
        <div class="text-4xl font-black text-blue-400 mb-1">35%+</div>
        <div class="text-xs text-gray-500 uppercase tracking-widest font-bold">
          Target attribution
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a
        href="#qualify"
        class="inline-flex items-center gap-2 px-8 py-4 bg-white text-e2-black rounded-full font-bold text-lg hover:scale-[1.02] transition-transform duration-300 shadow-xl shadow-black/30"
      >
        See If You Qualify →
      </a>
      <p class="text-xs text-gray-500 mt-3">
        No obligation · 30 minutes · Custom growth plan
      </p>
    </div>
  </div>
</section>
