                                R
                            </div>
                            <div>
                                <div class="font-bold text-white">
                                    Ryan Rizos
                                </div>
                                <div class="text-sm text-gray-400">
                                    Co-Founder &amp; CEO · BogeyBros
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col gap-4">
                        <BunnyVideo
                            libraryId="609841"
                            videoId="6f0c1382-ddd8-40f8-b4d4-f7e3a684f3e0"
                            title="How We Doubled BogeyBros Email Revenue in 90 Days"
                            subtitle="Ryan Rizos · Co-Founder & CEO, BogeyBros"
                            author="Ryan Rizos"
                            authorRole="Co-Founder & CEO, BogeyBros"
                        />
                        <div class="grid grid-cols-3 gap-3 text-center">
                            <div
                                class="rounded-xl bg-white/5 border border-white/10 p-4"
                            >
                                <div class="text-2xl font-black text-white">
                                    $300k
                                </div>
                                <div
                                    class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1"
                                >
                                    Record month
                                </div>
                            </div>
                            <div
                                class="rounded-xl bg-white/5 border border-white/10 p-4"
                            >
                                <div class="text-2xl font-black text-white">
                                    20+
                                </div>
                                <div
                                    class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1"
                                >
                                    Emails/mo
                                </div>
                            </div>
                            <div
                                class="rounded-xl bg-white/5 border border-white/10 p-4"
                            >
                                <div
                                    class="text-2xl font-black text-emerald-400"
                                >
                                    &lt;90
                                </div>
                                <div
                                    class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1"
                                >
                                    Days
                                </div>
                            </div>
                        </div>
                        <p class="text-xs text-gray-600 italic text-center">
                            Results verified via Klaviyo dashboard
                        </p>
                    </div>
                </div>
            </div>
        </div>

