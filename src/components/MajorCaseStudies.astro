---
import BunnyVideo from "./video/BunnyVideo.astro";
/**
 * MajorCaseStudies — 5 full-width hero case study cards
 * Extracted from CaseStudies.astro so /2 can use them independently.
 */
---

<section id="major-case-studies" class="py-32 relative overflow-hidden">
    <div
        class="absolute inset-0 bg-gradient-to-b from-gray-950 to-gray-950 pointer-events-none"
    >
    </div>
    <!-- Ambient glows -->
    <div
        class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-blue-600/10 rounded-full blur-[120px] pointer-events-none"
    >
    </div>
    <div
        class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-indigo-600/10 rounded-full blur-[100px] pointer-events-none"
    >
    </div>

    <div class="section-container relative z-10">
        <!-- Header -->
        <div class="max-w-3xl mx-auto text-center mb-16">
            <p
                class="text-xs font-bold uppercase tracking-widest text-blue-400 mb-4"
            >
                Proof
            </p>
            <h2
                class="font-bold text-4xl md:text-5xl mb-6 text-white tracking-tight text-balance"
            >
                Real Numbers.<br />
                <span class="text-gray-500">Real Brands. Real Revenue.</span>
            </h2>
            <p class="text-xl text-gray-400 leading-relaxed text-balance">
                Every result below is verified. Every number came from a Klaviyo
                or Shopify dashboard.
            </p>
        </div>

        <!-- Hero Case Study — Matt Orlic / Inspire Brands -->
        <div class="mb-12">
            <div
                class="rounded-[3rem] border border-white/10 bg-white/5 backdrop-blur-sm p-10 md:p-16 relative overflow-hidden"
            >
                <!-- Inner glow — orange/growth accent -->
                <div
                    class="absolute top-0 right-0 w-96 h-96 bg-orange-500/10 rounded-full blur-[80px] -mr-48 -mt-48 pointer-events-none"
                >
                </div>

                <div
                    class="relative z-10 grid md:grid-cols-2 gap-12 items-center"
                >
                    <!-- Left: story + quote -->
                    <div>
                        <div
                            class="inline-block px-3 py-1.5 rounded-full bg-orange-500/20 border border-orange-500/30 text-orange-400 text-xs font-bold uppercase tracking-widest mb-6"
                        >
                            8-Figure Multi-Brand Results
                        </div>

                        <!-- Before → After -->
                        <div class="flex items-center gap-4 mb-8">
                            <div class="text-center">
                                <div
                                    class="text-4xl font-black text-gray-500 tracking-tight"
                                >
                                    17%
                                </div>
                                <div
                                    class="text-xs text-gray-600 font-semibold uppercase tracking-wide mt-1"
                                >
                                    Before
                                </div>
                            </div>
                            <div
                                class="flex-1 flex items-center justify-center"
                            >
                                <div
                                    class="w-full h-px bg-gradient-to-r from-gray-700 via-orange-500 to-gray-700"
                                >
                                </div>
                                <div
                                    class="absolute px-3 py-1 rounded-full bg-orange-500/20 border border-orange-500/30 text-orange-400 text-sm font-black whitespace-nowrap"
                                >
                                    +80%
                                </div>
                            </div>
                            <div class="text-center">
                                <div
                                    class="text-4xl font-black text-white tracking-tight"
                                >
                                    30%+
                                </div>
                                <div
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide mt-1"
                                >
                                    After
                                </div>
                            </div>
                        </div>

                        <p
                            class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-6"
                        >
                            Email revenue share · 90 days · rolled out across
                            all 8-figure brands
                        </p>

                        <blockquote
                            class="text-xl text-gray-300 leading-relaxed mb-8 italic"
                        >
                            "We were hovering around 16-17%. Now we're over 30
                            and you can't express what a massive difference that
                            makes in an eCommerce business. One campaign - we
                            achieved $100,000 in a single day just via email.
                            The investment we paid back within the first week
                            alone."
                        </blockquote>

                        <div class="flex items-center gap-4">
                            <div
                                class="w-12 h-12 rounded-full bg-gradient-to-br from-orange-900 to-gray-900 border border-orange-500/20 flex items-center justify-center text-orange-400 text-sm font-black flex-shrink-0"
                            >
                                M
                            </div>
                            <div>
                                <div class="font-bold text-white">
                                    Matt Orlic
                                </div>
                                <div class="text-sm text-gray-400">
                                    Founder · Inspire Brands (8-Figure eCom)
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col gap-4">
                        <BunnyVideo
                            libraryId="609841"
                            videoId="b1589b6d-f62d-4ab2-b4db-ba2711e36f33"
                            title="How Inspire Brands Grew Email Revenue Across Multiple 8-Figure Stores"
                            subtitle="Matt Orlic · Founder, Inspire Brands"
                            author="Matt Orlic"
                            authorRole="Founder, Inspire Brands"
                        />
                        <div class="grid grid-cols-3 gap-3 text-center">
                            <div
                                class="rounded-xl bg-white/5 border border-white/10 p-4"
                            >
                                <div
                                    class="text-2xl font-black text-orange-400"
                                >
                                    $100k
                                </div>
                                <div
                                    class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1"
                                >
                                    Single campaign day
                                </div>
                            </div>
                            <div
                                class="rounded-xl bg-white/5 border border-white/10 p-4"
                            >
                                <div class="text-2xl font-black text-white">
                                    90
                                </div>
                                <div
                                    class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1"
                                >
                                    Days
                                </div>
                            </div>
                            <div
                                class="rounded-xl bg-white/5 border border-white/10 p-4"
                            >
                                <div class="text-2xl font-black text-white">
                                    8-fig
                                </div>
                                <div
                                    class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1"
                                >
                                    Brand scale
                                </div>
                            </div>
                        </div>
                        <p class="text-xs text-gray-600 italic text-center">
                            Results verified · implemented across multiple eCom
                            brands
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hero Case Study #2 — BogeyBros -->

        <div class="mb-12">
            <div
                class="rounded-[3rem] border border-white/10 bg-white/5 backdrop-blur-sm p-10 md:p-16 relative overflow-hidden"
            >
                <!-- Inner glow — green/golf accent -->
                <div
                    class="absolute top-0 right-0 w-96 h-96 bg-emerald-500/10 rounded-full blur-[80px] -mr-48 -mt-48 pointer-events-none"
                >
                </div>

                <div
                    class="relative z-10 grid md:grid-cols-2 gap-12 items-center"
                >
                    <!-- Left: story + quote -->
                    <div>
                        <div
                            class="inline-block px-3 py-1.5 rounded-full bg-emerald-500/20 border border-emerald-500/30 text-emerald-400 text-xs font-bold uppercase tracking-widest mb-6"
                        >
                            The Email Frequency Build
                        </div>

                        <!-- Before → After -->
                        <div class="flex items-center gap-4 mb-8">
                            <div class="text-center">
                                <div
                                    class="text-4xl font-black text-gray-500 tracking-tight"
                                >
                                    $100k
                                </div>
                                <div
                                    class="text-xs text-gray-600 font-semibold uppercase tracking-wide mt-1"
                                >
                                    Before
                                </div>
                            </div>
                            <div
                                class="flex-1 flex items-center justify-center"
                            >
                                <div
                                    class="w-full h-px bg-gradient-to-r from-gray-700 via-emerald-500 to-gray-700"
                                >
                                </div>
                                <div
                                    class="absolute px-3 py-1 rounded-full bg-emerald-500/20 border border-emerald-500/30 text-emerald-400 text-sm font-black whitespace-nowrap"
                                >
                                    +100%
                                </div>
                            </div>
                            <div class="text-center">
                                <div
                                    class="text-4xl font-black text-white tracking-tight"
                                >
                                    $200k+
                                </div>
                                <div
                                    class="text-xs text-gray-400 font-semibold uppercase tracking-wide mt-1"
                                >
                                    After
                                </div>
                            </div>
