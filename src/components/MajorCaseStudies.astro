                            projects
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hero Case Study #4 — Nightbuddy (ECOMX) -->
        <div class="mb-12">
            <div
                class="rounded-[3rem] border border-white/10 bg-white/5 backdrop-blur-sm p-10 md:p-16 relative overflow-hidden"
            >
                <div
                    class="absolute bottom-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-amber-500/8 rounded-full blur-[100px] pointer-events-none"
                >
                </div>

                <div
                    class="relative z-10 grid md:grid-cols-2 gap-12 items-center"
                >
                    <div>
                        <div
                            class="inline-block px-3 py-1.5 rounded-full bg-amber-500/20 border border-amber-500/30 text-amber-400 text-xs font-bold uppercase tracking-widest mb-6"
