---
/**
 * Mechanism / How It Works - 3 Steps
 * Per 2026 playbook: exactly 3 steps (cognitive load reduction)
 * StoryBrand: clear plan removes hesitation, makes buying decision feel safe
 * All section copy is dynamic from the variant for narrative congruency
 */
import { DEFAULT_VARIANT } from "../lib/supabase";

interface Props {
  heading?: string;
  subheading?: string;
  step1Label?: string;
  step1Desc?: string;
  step1Bullets?: string[];
  step2Label?: string;
  step2Desc?: string;
  step2Bullets?: string[];
  step3Label?: string;
  step3Desc?: string;
  step3Bullets?: string[];
}

const {
  heading = DEFAULT_VARIANT.mech_heading,
  subheading = DEFAULT_VARIANT.mech_subheading,
  step1Label = DEFAULT_VARIANT.mech_step1_label,
  step1Desc = DEFAULT_VARIANT.mech_step1_desc,
  step1Bullets = DEFAULT_VARIANT.mech_step1_bullets,
  step2Label = DEFAULT_VARIANT.mech_step2_label,
  step2Desc = DEFAULT_VARIANT.mech_step2_desc,
  step2Bullets = DEFAULT_VARIANT.mech_step2_bullets,
  step3Label = DEFAULT_VARIANT.mech_step3_label,
  step3Desc = DEFAULT_VARIANT.mech_step3_desc,
  step3Bullets = DEFAULT_VARIANT.mech_step3_bullets,
} = Astro.props;

const isAdmin = !!(Astro.locals as any).isAdmin;
const editProps = (field: string) =>
  isAdmin
    ? {
        contenteditable: "false",
        "data-field": field,
        spellcheck: false as const,
      }
    : {};
---

<section
  id="how-it-works"
  class="h-[100svh] min-h-[750px] relative flex items-center"
>
  <div
    class="absolute inset-0 bg-gradient-to-b from-white via-gray-50/30 to-white pointer-events-none"
  >
  </div>

  <div class="section-container relative z-10 w-full">
    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center mb-10">
      <p class="text-xs font-bold uppercase tracking-widest text-blue-600 mb-3">
        How It Works
      </p>
      <h2
        class="font-bold text-4xl md:text-5xl mb-4 text-e2-black tracking-tight text-balance"
      >
        <span {...editProps('mech_heading')}>{heading}</span><br />
        <span class="text-gray-400">Built in 3 Steps.</span>
      </h2>
      <p
        class="text-lg text-gray-500 leading-relaxed text-balance"
        {...editProps('mech_subheading')}
      >
        {subheading}
      </p>
    </div>

    <!-- 3-Step Layout -->
    <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-6 mb-10">
      <!-- Step 1 -->
      <div class="relative group">
        <!-- Connector line (desktop) -->
        <div
          class="hidden md:block absolute top-10 left-full w-full h-px bg-gradient-to-r from-gray-200 to-transparent z-0 -mr-8"
        >
        </div>

        <div
          class="relative z-10 glass-panel rounded-3xl p-6 h-full hover:-translate-y-1 transition-all duration-500 border border-white/80"
        >
          <div
            class="w-10 h-10 rounded-2xl bg-blue-600 text-white font-black text-lg flex items-center justify-center mb-5 shadow-lg shadow-blue-600/25"
          >
            1
          </div>
          <h3
            class="font-bold text-lg text-e2-black mb-2"
            {...editProps('mech_step1_label')}
          >
            {step1Label}
          </h3>
          <p
            class="text-gray-500 leading-relaxed text-sm"
            {...editProps('mech_step1_desc')}
          >
            {step1Desc}
          </p>
          <div class="mt-5 pt-5 border-t border-gray-100">
            <p
              class="text-xs font-bold text-gray-400 uppercase tracking-wide mb-2"
            >
              What you get
            </p>
            <ul class="space-y-1.5 text-sm text-gray-600">
              {
                step1Bullets.map((bullet) => (
                  <li
                    class="flex items-center gap-2"
                    data-list-field="mech_step1_bullets"
                    spellcheck={false}
                  >
                    <span class="w-1.5 h-1.5 rounded-full bg-blue-400 shrink-0" />
                    {bullet}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="relative group">
        <div
          class="hidden md:block absolute top-10 left-full w-full h-px bg-gradient-to-r from-gray-200 to-transparent z-0 -mr-8"
        >
        </div>

        <div
          class="relative z-10 glass-panel rounded-3xl p-6 h-full hover:-translate-y-1 transition-all duration-500 border border-white/80"
        >
          <div
            class="w-10 h-10 rounded-2xl bg-indigo-600 text-white font-black text-lg flex items-center justify-center mb-5 shadow-lg shadow-indigo-600/25"
          >
            2
          </div>
          <h3
            class="font-bold text-lg text-e2-black mb-2"
            {...editProps('mech_step2_label')}
          >
            {step2Label}
          </h3>
          <p
            class="text-gray-500 leading-relaxed text-sm"
            {...editProps('mech_step2_desc')}
          >
            {step2Desc}
          </p>
          <div class="mt-5 pt-5 border-t border-gray-100">
            <p
              class="text-xs font-bold text-gray-400 uppercase tracking-wide mb-2"
            >
              What you get
            </p>
            <ul class="space-y-1.5 text-sm text-gray-600">
              {
                step2Bullets.map((bullet) => (
                  <li
                    class="flex items-center gap-2"
                    data-list-field="mech_step2_bullets"
                    spellcheck={false}
                  >
                    <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 shrink-0" />
                    {bullet}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="relative group">
        <div
          class="relative z-10 glass-panel rounded-3xl p-6 h-full hover:-translate-y-1 transition-all duration-500 border border-white/80"
        >
          <div
            class="w-10 h-10 rounded-2xl bg-green-600 text-white font-black text-lg flex items-center justify-center mb-5 shadow-lg shadow-green-600/25"
          >
            3
          </div>
          <h3
            class="font-bold text-lg text-e2-black mb-2"
            {...editProps('mech_step3_label')}
          >
            {step3Label}
          </h3>
          <p
            class="text-gray-500 leading-relaxed text-sm"
            {...editProps('mech_step3_desc')}
          >
            {step3Desc}
          </p>
          <div class="mt-5 pt-5 border-t border-gray-100">
            <p
              class="text-xs font-bold text-gray-400 uppercase tracking-wide mb-2"
            >
              What you get
            </p>
            <ul class="space-y-1.5 text-sm text-gray-600">
              {
                step3Bullets.map((bullet) => (
                  <li
                    class="flex items-center gap-2"
                    data-list-field="mech_step3_bullets"
                    spellcheck={false}
                  >
                    <span class="w-1.5 h-1.5 rounded-full bg-green-400 shrink-0" />
                    {bullet}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a
        href="#qualify"
        class="inline-flex items-center gap-2 px-8 py-4 bg-e2-black text-white rounded-full font-bold text-lg hover:scale-[1.02] transition-transform duration-300 shadow-xl shadow-black/10"
      >
        Book Your Free Audit Call →
      </a>
      <p class="text-xs text-gray-400 mt-3">
        30 minutes. No obligation. See exactly what we'd build for your brand.
      </p>
    </div>
  </div>
</section>
