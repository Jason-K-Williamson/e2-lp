---
/**
 * The Offer - Mafia Offer breakdown (Hormozi-style)
 * Entire section is AI-generated from offer_cards jsonb + offer_* fields.
 * Color classes are explicit strings (not dynamic) for Tailwind purge safety.
 * All card titles, descriptions, and item names/descs are tagged with
 * data-field="offer_cards.{cardIdx}.{key}" so the visual editor can
 * reconstruct the JSONB on save.
 */
import { DEFAULT_VARIANT, type OfferCard } from "../lib/supabase";

interface Props {
  heading?: string;
  subheading?: string;
  summaryTitle?: string;
  summaryBody?: string;
  cards?: OfferCard[];
}

const {
  heading = DEFAULT_VARIANT.offer_heading,
  subheading = DEFAULT_VARIANT.offer_subheading,
  summaryTitle = DEFAULT_VARIANT.offer_summary_title,
  summaryBody = DEFAULT_VARIANT.offer_summary_body,
  cards = DEFAULT_VARIANT.offer_cards as OfferCard[],
} = Astro.props;

const isAdmin = !!(Astro.locals as any).isAdmin;
const editProps = (field: string) =>
  isAdmin
    ? {
        contenteditable: "false",
        "data-field": field,
        spellcheck: false as const,
      }
    : {};

// Tailwind colour map — explicit classes so purge keeps them
const colourMap: Record<string, { bg: string; text: string; dot: string }> = {
  blue: {
    bg: "bg-blue-600",
    text: "text-blue-600",
    dot: "bg-blue-100 text-blue-600",
  },
  indigo: {
    bg: "bg-indigo-600",
    text: "text-indigo-600",
    dot: "bg-indigo-100 text-indigo-600",
  },
  violet: {
    bg: "bg-violet-600",
    text: "text-violet-600",
    dot: "bg-violet-100 text-violet-600",
  },
  emerald: {
    bg: "bg-emerald-600",
    text: "text-emerald-600",
    dot: "bg-emerald-100 text-emerald-600",
  },
};
---

<section id="offer" class="py-32 relative bg-white">
  {
    /* Side-channel: VisualEditor reads this to reconstruct offer_cards JSONB on save */
  }
  {
    isAdmin && (
      <script
        id="ve-offer-cards-meta"
        type="application/json"
        set:html={JSON.stringify(cards)}
      />
    )
  }

  <div class="section-container">
    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center mb-16">
      <p class="text-sm font-bold uppercase tracking-widest text-blue-600 mb-4">
        What You Actually Get
      </p>
      <h2
        class="font-bold text-4xl md:text-5xl text-e2-black tracking-tight mb-6"
        {...editProps("offer_heading")}
      >
        {heading}<br />
        <span class="text-gray-400">Built Once. Yours Forever.</span>
      </h2>
      <p class="text-xl text-gray-500" {...editProps("offer_subheading")}>
        {subheading}
      </p>
    </div>

    <!-- Deliverable Cards — fully rendered from offer_cards DB field -->
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-6 mb-12">
      {
        cards.map((card, ci) => {
          const c = colourMap[card.color] ?? colourMap.blue;
          return (
            <div class="rounded-3xl border border-gray-100 bg-gray-50 p-8 shadow-sm">
              <div class="flex items-center gap-3 mb-5">
                <div
                  class={`w-10 h-10 rounded-2xl ${c.bg} flex items-center justify-center text-white text-lg`}
                >
                  {card.icon}
                </div>
                <div>
                  <p
                    class={`text-xs font-bold uppercase tracking-widest ${c.text}`}
                    {...editProps(`offer_cards.${ci}.block`)}
                  >
                    {card.block}
                  </p>
                  <h3
                    class="font-bold text-lg text-e2-black"
                    {...editProps(`offer_cards.${ci}.title`)}
                  >
                    {card.title}
                  </h3>
                </div>
              </div>
              <p
                class="text-sm text-gray-500 mb-5"
                {...editProps(`offer_cards.${ci}.desc`)}
              >
                {card.desc}
              </p>
              <ul class="space-y-3">
                {card.items.map((item, ii) => (
                  <li class="flex gap-3">
                    <div
                      class={`mt-0.5 w-5 h-5 rounded-full ${c.dot} flex items-center justify-center text-xs flex-shrink-0`}
                    >
                      ✓
                    </div>
                    <div>
                      <span
                        class="font-semibold text-e2-black text-sm"
                        {...editProps(`offer_cards.${ci}.items.${ii}.name`)}
                      >
                        {item.name}
                      </span>
                      <p
                        class="text-xs text-gray-400 mt-0.5"
                        {...editProps(`offer_cards.${ci}.items.${ii}.desc`)}
                      >
                        {item.desc}
                      </p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<!-- ===== MAFIA OFFER ===== -->
<section
  id="mafia-offer"
  class="h-[100svh] min-h-[750px] relative overflow-hidden bg-e2-black flex items-center"
>
  <!-- Ambient effects -->
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-blue-600/8 rounded-full blur-[130px] pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-indigo-600/5 rounded-full blur-[100px] pointer-events-none"
  >
  </div>

  <div class="section-container relative z-10 w-full max-w-5xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: The pitch -->
      <div>
        <span
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-xs font-bold uppercase tracking-widest mb-8 block w-fit"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"
          ></span>
          The Mafia Offer
        </span>

        <h2
          class="text-4xl md:text-5xl lg:text-6xl font-black text-white tracking-tight mb-6 leading-tight text-balance"
        >
          6 Flows. SMS.<br />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400"
            >A Full Team.</span
          ><br />
          One Flat Fee.
        </h2>

        <p class="text-xl text-gray-400 leading-relaxed mb-10">
          You get the complete email and SMS system for your brand. Six custom
          flows, a full SMS channel, senior copywriters, designers, and Klaviyo
          specialists. All built once. You own it. No retainer.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="#qualify"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-e2-black rounded-full font-bold text-lg hover:scale-[1.02] transition-transform duration-300 shadow-xl shadow-black/30"
          >
            See If You Qualify →
          </a>
        </div>
        <p class="text-xs text-gray-600 mt-4">
          No obligation · 30 minutes · Custom growth plan
        </p>
        <p class="text-xs text-gray-600 mt-1">
          Most agencies charge $3,000–$8,000/month for a fraction of this. We do
          it once.
        </p>
      </div>

      <!-- Right: What's included -->
      <div class="space-y-3">
        <p
          class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-5"
        >
          Everything included
        </p>

        {
          [
            {
              icon: "✉️",
              label: "6 Custom Email Flows",
              desc: "Welcome, Abandoned Checkout, Added to Cart, Browse Abandonment, Post-Purchase, Win-Back",
            },
            {
              icon: "📱",
              label: "Full SMS Channel",
              desc: "Klaviyo SMS or Postscript, built and integrated alongside your email flows",
            },
            {
              icon: "✍️",
              label: "Brand Copywriter",
              desc: "Human-written copy built for your specific customer, voice, and product",
            },
            {
              icon: "🎨",
              label: "Custom Email Design",
              desc: "HTML templates built to your brand guidelines. Not stock layouts.",
            },
            {
              icon: "🔬",
              label: "Deliverability Audit",
              desc: "Domain warmup, list hygiene, inbox placement — fixed before we send anything",
            },
            {
              icon: "📊",
              label: "Full Klaviyo Setup",
              desc: "Segmentation, triggers, flows tested and optimised before handoff",
            },
            {
              icon: "🛡️",
              label: "Revenue-or-Rebuild Guarantee",
              desc: "No revenue lift in 90 days? We rebuild every underperforming flow at no charge.",
            },
          ].map((item) => (
            <div class="flex items-start gap-4 rounded-2xl bg-white/5 border border-white/8 px-5 py-4">
              <span class="text-xl shrink-0 mt-0.5">{item.icon}</span>
              <div>
                <div class="font-bold text-white text-sm">{item.label}</div>
                <div class="text-gray-500 text-xs mt-0.5">{item.desc}</div>
              </div>
              <div class="ml-auto shrink-0">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  class="w-5 h-5 text-emerald-400"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                    clip-rule="evenodd"
                  />
                </svg>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
