---
/**
 * The Offer - Mafia Offer breakdown (Hormozi-style)
 * Entire section is AI-generated from offer_cards jsonb + offer_* fields.
 * Color classes are explicit strings (not dynamic) for Tailwind purge safety.
 * All card titles, descriptions, and item names/descs are tagged with
 * data-field="offer_cards.{cardIdx}.{key}" so the visual editor can
 * reconstruct the JSONB on save.
 */
import { DEFAULT_VARIANT, type OfferCard } from "../lib/supabase";

interface Props {
  heading?: string;
  subheading?: string;
  summaryTitle?: string;
  summaryBody?: string;
  cards?: OfferCard[];
}

const {
  heading = DEFAULT_VARIANT.offer_heading,
  subheading = DEFAULT_VARIANT.offer_subheading,
  summaryTitle = DEFAULT_VARIANT.offer_summary_title,
  summaryBody = DEFAULT_VARIANT.offer_summary_body,
  cards = DEFAULT_VARIANT.offer_cards as OfferCard[],
} = Astro.props;

const isAdmin = !!(Astro.locals as any).isAdmin;
const editProps = (field: string) =>
  isAdmin
    ? {
        contenteditable: "false",
        "data-field": field,
        spellcheck: false as const,
      }
    : {};

// Tailwind colour map — explicit classes so purge keeps them
const colourMap: Record<string, { bg: string; text: string; dot: string }> = {
  blue: {
    bg: "bg-blue-600",
    text: "text-blue-600",
    dot: "bg-blue-100 text-blue-600",
  },
  indigo: {
    bg: "bg-indigo-600",
    text: "text-indigo-600",
    dot: "bg-indigo-100 text-indigo-600",
  },
  violet: {
    bg: "bg-violet-600",
    text: "text-violet-600",
    dot: "bg-violet-100 text-violet-600",
  },
  emerald: {
    bg: "bg-emerald-600",
    text: "text-emerald-600",
    dot: "bg-emerald-100 text-emerald-600",
  },
};
---

<section id="offer" class="py-32 relative bg-white">
  {
    /* Side-channel: VisualEditor reads this to reconstruct offer_cards JSONB on save */
  }
  {
    isAdmin && (
      <script
        id="ve-offer-cards-meta"
        type="application/json"
        set:html={JSON.stringify(cards)}
      />
    )
  }

  <div class="section-container">
    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center mb-16">
      <p class="text-sm font-bold uppercase tracking-widest text-blue-600 mb-4">
        What You Actually Get
      </p>
      <h2
        class="font-bold text-4xl md:text-5xl text-e2-black tracking-tight mb-6"
        {...editProps("offer_heading")}
      >
        {heading}<br />
        <span class="text-gray-400">Built Once. Yours Forever.</span>
      </h2>
      <p class="text-xl text-gray-500" {...editProps("offer_subheading")}>
        {subheading}
      </p>
    </div>

    <!-- Deliverable Cards — fully rendered from offer_cards DB field -->
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-6 mb-12">
      {
        cards.map((card, ci) => {
          const c = colourMap[card.color] ?? colourMap.blue;
          return (
            <div class="rounded-3xl border border-gray-100 bg-gray-50 p-8 shadow-sm">
              <div class="flex items-center gap-3 mb-5">
                <div
                  class={`w-10 h-10 rounded-2xl ${c.bg} flex items-center justify-center text-white text-lg`}
                >
                  {card.icon}
                </div>
                <div>
                  <p
                    class={`text-xs font-bold uppercase tracking-widest ${c.text}`}
                    {...editProps(`offer_cards.${ci}.block`)}
                  >
                    {card.block}
                  </p>
                  <h3
                    class="font-bold text-lg text-e2-black"
                    {...editProps(`offer_cards.${ci}.title`)}
                  >
                    {card.title}
                  </h3>
                </div>
              </div>
              <p
                class="text-sm text-gray-500 mb-5"
                {...editProps(`offer_cards.${ci}.desc`)}
              >
                {card.desc}
              </p>
              <ul class="space-y-3">
                {card.items.map((item, ii) => (
                  <li class="flex gap-3">
                    <div
                      class={`mt-0.5 w-5 h-5 rounded-full ${c.dot} flex items-center justify-center text-xs flex-shrink-0`}
                    >
                      ✓
                    </div>
                    <div>
                      <span
                        class="font-semibold text-e2-black text-sm"
                        {...editProps(`offer_cards.${ci}.items.${ii}.name`)}
                      >
                        {item.name}
                      </span>
                      <p
                        class="text-xs text-gray-400 mt-0.5"
                        {...editProps(`offer_cards.${ci}.items.${ii}.desc`)}
                      >
                        {item.desc}
                      </p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          );
        })
      }
    </div>

    <!-- Total Value Summary + CTA -->
    <div
      class="max-w-2xl mx-auto rounded-3xl bg-e2-black text-white p-10 text-center shadow-2xl shadow-black/20"
    >
      <p class="text-sm font-bold uppercase tracking-widest text-blue-400 mb-3">
        The Mafia Offer
      </p>
      <h3
        class="text-3xl font-bold mb-3 tracking-tight"
        {...editProps("offer_summary_title")}
      >
        {summaryTitle}
      </h3>
      <p
        class="text-gray-400 mb-8 text-sm leading-relaxed"
        {...editProps("offer_summary_body")}
      >
        {summaryBody}
      </p>
      <p class="text-gray-500 text-xs mb-8">
        Most agencies charge $3,000–$8,000/month for a fraction of this. We do
        it once. Book a call to get your number.
      </p>
      <a
        href="#qualify"
        class="inline-block px-10 py-4 rounded-xl bg-white text-e2-black font-bold text-lg hover:scale-[1.02] transition-transform shadow-xl"
      >
        See If You Qualify →
      </a>
      <p class="text-xs text-gray-500 mt-4">
        No obligation · 30 minutes · We'll identify at least 20% growth
        potential or we'll tell you we're not the right fit.
      </p>
    </div>
  </div>
</section>
