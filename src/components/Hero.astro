---
const headline = "Stop Burning Cash on Traffic That Doesn't Convert";
const subheadline =
  "We've generated $220M+ for DTC brands using 6 automated flows. Most clients see 30–40% more revenue within 7 days of going live.";
---

<section class="relative min-h-[95vh] flex flex-col justify-center pt-32 pb-20">
  <!-- Ambient Background: lightweight radial gradient (no GPU blur) -->
  <div
    class="absolute top-0 inset-x-0 h-[100vh] pointer-events-none"
    style="background: radial-gradient(ellipse 80% 60% at 50% 30%, rgba(219,234,254,0.3) 0%, transparent 70%);"
  >
  </div>

  <div
    class="section-container relative z-10 flex flex-col items-center text-center"
  >
    <!-- Badge: Ultra subtle glass pill -->
    <div
      data-animate
      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-gray-200/60 bg-white/50 backdrop-blur-md text-xs font-semibold text-gray-800 mb-10 shadow-sm"
    >
      <span class="relative flex h-2 w-2">
        <span
          class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"
        ></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"
        ></span>
      </span>
      2 Spots Left — February Intake Closes Friday
    </div>

    <!-- Typography: Massive, tight, clean -->
    <h1
      data-animate
      class="max-w-4xl font-bold text-[clamp(3.5rem,8vw,5.5rem)] leading-[0.95] tracking-tight text-e2-black mb-10 text-balance"
    >
      {headline}
    </h1>

    <p
      data-animate
      class="text-xl md:text-2xl text-gray-500 max-w-2xl mx-auto mb-12 leading-relaxed font-normal text-balance"
    >
      {subheadline}
    </p>

    <!-- Buttons -->
    <div
      data-animate
      class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto"
    >
      <a
        href="#offer"
        class="w-full sm:w-auto px-8 py-4 bg-e2-black text-white rounded-full font-semibold text-lg hover:scale-[1.02] transition-transform duration-300 shadow-xl shadow-black/5"
      >
        See If You Qualify →
      </a>
      <a
        href="#mechanism"
        class="w-full sm:w-auto px-8 py-4 bg-white text-e2-black border border-gray-200 rounded-full font-semibold text-lg hover:bg-gray-50 transition-colors duration-300"
      >
        How It Works
      </a>
    </div>

    <!-- Trust -->
    <div
      data-animate
      class="mt-16 pt-8 border-t border-gray-100 w-full max-w-lg"
    >
      <p
        class="text-[10px] uppercase tracking-widest text-gray-400 font-semibold mb-4 text-center"
      >
        Trusted By
      </p>
      <div
        class="flex items-center justify-center flex-wrap gap-x-8 gap-y-3 opacity-50 grayscale hover:grayscale-0 transition-all duration-500"
      >
        <!-- Simple text representation for logos to keep it clean if no SVGs -->
        <span class="font-bold font-display text-gray-800 text-sm"
          >THE OODIE</span
        >
        <span class="font-bold font-display text-gray-800 text-sm">TWOSVGE</span
        >
        <span class="font-bold font-display text-gray-800 text-sm">OTAA</span>
        <span class="font-bold font-display text-gray-800 text-sm"
          >BOGEY BROS</span
        >
        <span class="font-bold font-display text-gray-800 text-sm"
          >CALMING BLANKETS</span
        >
        <span class="font-bold font-display text-gray-800 text-sm"
          >ELITE SUPPLEMENTS</span
        >
        <span class="font-bold font-display text-gray-800 text-sm"
          >CANVAS CULTURES</span
        >
        <span class="text-xs text-gray-400 font-semibold">+ 750 more</span>
      </div>
    </div>
  </div>
</section>
