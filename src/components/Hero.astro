---
import { DEFAULT_VARIANT } from "../lib/supabase";
import { LogoCloud } from "./ui/logo-cloud-2";

interface Props {
  badge?: string;
  headline?: string;
  subheadline?: string;
  ctaPrimary?: string;
  ctaSecondary?: string;
}

const {
  badge = DEFAULT_VARIANT.hero_badge,
  headline = DEFAULT_VARIANT.hero_headline,
  subheadline = DEFAULT_VARIANT.hero_subheadline,
  ctaPrimary = DEFAULT_VARIANT.hero_cta_primary,
  ctaSecondary = DEFAULT_VARIANT.hero_cta_secondary,
} = Astro.props;

const isAdmin = !!(Astro.locals as any).isAdmin;

const editProps = (field: string) =>
  isAdmin
    ? {
        contenteditable: "false",
        "data-field": field,
        spellcheck: false as const,
      }
    : {};
---

<section
  class="relative min-h-screen flex flex-col justify-center pt-16 pb-24 overflow-hidden"
>
  <!-- Multi-layer ambient background -->
  <div class="absolute inset-0 pointer-events-none">
    <div
      style="background: radial-gradient(ellipse 90% 70% at 50% 20%, rgba(219,234,254,0.35) 0%, transparent 65%);position:absolute;inset:0;"
    >
    </div>
    <div
      style="background: radial-gradient(ellipse 50% 50% at 80% 80%, rgba(233,213,255,0.15) 0%, transparent 60%);position:absolute;inset:0;"
    >
    </div>
  </div>

  <div
    class="section-container relative z-10 flex flex-col items-center text-center"
  >
    <!-- Badge -->
    <div
      data-animate
      class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-gray-200/70 bg-white/60 backdrop-blur-md text-xs font-bold text-gray-900 mb-8 shadow-sm tracking-wide"
    >
      <span class="relative flex h-2 w-2">
        <span
          class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"
          style="will-change: transform;"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"
        ></span>
      </span>
      <span {...editProps("hero_badge")}>{badge}</span>
    </div>

    <!-- Headline -->
    <h1
      id="hero-headline"
      data-animate
      class="max-w-3xl font-bold text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.05] tracking-tight text-e2-black mb-5 text-balance"
      {...editProps("hero_headline")}
    >
      {headline}
    </h1>

    <!-- Subheadline -->
    <p
      data-animate
      class="text-base md:text-lg text-gray-500 max-w-xl mx-auto mb-8 leading-relaxed font-normal text-balance"
      {...editProps("hero_subheadline")}
    >
      {subheadline}
    </p>

    <!-- CTA Group -->
    <div
      data-animate
      class="flex flex-col sm:flex-row items-center gap-3 w-full sm:w-auto mb-4"
    >
      <a
        href="#qualify"
        id="hero-cta-primary"
        class="group w-full sm:w-auto px-9 py-4 bg-e2-black text-white rounded-full font-bold text-lg hover:bg-gray-900 transition-all duration-300 shadow-2xl shadow-black/20 flex items-center justify-center gap-2 relative overflow-hidden"
        {...editProps("hero_cta_primary")}
      >
        <span class="relative z-10">{ctaPrimary}</span>
        <span
          class="absolute inset-0 bg-gradient-to-r from-gray-900 to-gray-800 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
        ></span>
      </a>
      <a
        href="#how-it-works"
        class="w-full sm:w-auto px-7 py-4 bg-white/80 backdrop-blur-sm text-e2-black border border-gray-200 rounded-full font-semibold text-lg hover:bg-white hover:shadow-lg transition-all duration-300"
        {...editProps("hero_cta_secondary")}
      >
        {ctaSecondary}
      </a>
    </div>

    <!-- Micro-copy trust line -->
    <p
      data-animate
      class="text-xs text-gray-400 font-medium mb-16 tracking-wide"
    >
      No obligation &nbsp;·&nbsp; 30 minutes &nbsp;·&nbsp; Custom growth plan
    </p>

    <!-- VSL Placeholder -->
    <div
      data-animate
      class="w-full max-w-4xl mx-auto shrink-0 relative rounded-[2rem] overflow-hidden shadow-2xl shadow-black/20 border border-white/50 group cursor-pointer aspect-[4/3]"
      id="vsl-player"
      role="button"
      aria-label="Watch our case study video"
    >
      <!-- Dark cinematic background -->
      <div
        class="w-full h-full bg-gradient-to-br from-gray-950 via-gray-900 to-black flex flex-col items-center justify-center relative"
      >
        <!-- Subtle texture overlay -->
        <div
          class="absolute inset-0 opacity-30"
          style="background-image: radial-gradient(circle at 25% 25%, rgba(99,102,241,0.2) 0%, transparent 50%), radial-gradient(circle at 75% 75%, rgba(139,92,246,0.15) 0%, transparent 50%);"
        >
        </div>

        <!-- Floating stat chips -->
        <div
          class="absolute top-4 left-4 sm:top-6 sm:left-6 px-3 py-1.5 rounded-full bg-white/10 backdrop-blur border border-white/20 text-white/90 text-xs font-bold tracking-wide"
        >
          The E2 Mafia Offer
        </div>
        <div
          class="absolute top-4 right-4 sm:top-6 sm:right-6 px-3 py-1.5 rounded-full bg-indigo-500/20 backdrop-blur border border-indigo-500/30 text-indigo-300 text-[10px] sm:text-xs font-bold flex items-center gap-1.5 uppercase tracking-wider"
        >
          <span class="relative flex h-1.5 w-1.5 sm:h-2 sm:w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"
            ></span>
            <span
              class="relative inline-flex rounded-full h-1.5 w-1.5 sm:h-2 sm:w-2 bg-indigo-500"
            ></span>
          </span>
          Play Video
        </div>

        <!-- Center VSL Content -->
        <div
          class="relative z-10 flex flex-col items-center gap-3 sm:gap-5 px-4 mt-2 sm:mt-6"
        >
          <div
            class="w-14 h-14 sm:w-20 sm:h-20 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center group-hover:scale-110 group-hover:bg-white/25 transition-all duration-500 shadow-2xl"
          >
            <svg
              class="w-6 h-6 sm:w-8 sm:h-8 text-white ml-1"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M8 5v14l11-7z"></path>
            </svg>
          </div>
          <div class="text-center max-w-xl mx-auto">
            <p
              class="text-white font-black text-lg sm:text-2xl md:text-3xl mb-1 sm:mb-2 leading-tight tracking-tight text-balance"
            >
              We build your complete email system & <span
                class="text-indigo-400">guarantee a 3X ROI</span
              > in 90 days.
            </p>
            <p
              class="text-slate-300 text-[11px] sm:text-sm font-medium tracking-wide"
            >
              Click to watch exactly how we do it step-by-step
            </p>
          </div>
        </div>

        <!-- Bottom bar -->
        <div
          class="absolute bottom-0 left-0 right-0 px-4 sm:px-6 py-3 sm:py-4 bg-gradient-to-t from-black/95 via-black/60 to-transparent flex flex-col sm:flex-row sm:items-center justify-between gap-2"
        >
          <div class="flex items-center gap-3">
            <div
              class="w-8 h-8 rounded-full bg-gradient-to-br from-indigo-600 to-indigo-900 border border-white/20 flex items-center justify-center text-white text-[10px] sm:text-xs font-black flex-shrink-0 shadow-inner"
            >
              JW
            </div>
            <div class="text-left">
              <p
                class="text-white text-[11px] sm:text-xs font-bold tracking-wide"
              >
                Jason Williamson
              </p>
              <p
                class="text-slate-400 text-[9px] sm:text-[10px] uppercase font-bold tracking-[0.2em] mt-0.5"
              >
                Founder, e2 Agency
              </p>
            </div>
          </div>
          <div class="flex items-center gap-1.5 self-start sm:self-auto">
            <span
              class="text-indigo-400 text-[9px] sm:text-[10px] font-bold px-2 py-1 bg-indigo-900/30 rounded border border-indigo-500/20 uppercase tracking-[0.15em] backdrop-blur-sm"
              >Highly Valuable Strategy</span
            >
          </div>
        </div>
      </div>
    </div>

    <!-- Below VSL social proof row -->
    <div class="mt-10 w-full max-w-3xl">
      <p
        class="text-base uppercase tracking-widest text-gray-400 font-semibold mb-2 text-center"
      >
        Trusted By USA & Australia's Leading D2C Brands
      </p>
      <p class="text-base text-gray-400 font-medium text-center mb-6">
        Join 750+ brands who've scaled their email & SMS with e2
      </p>
      <LogoCloud client:load className="w-full" />
    </div>
  </div>
</section>
