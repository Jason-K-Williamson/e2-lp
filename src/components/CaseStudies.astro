---
import BunnyVideo from "./video/BunnyVideo.astro";
/**
 * Case Studies , Deep Social Proof
 * Per 2026 playbook: mini case study format with before→after numbers
 * "Specific numbers beat vague claims" , Columbia University research
 * Format: client name, situation, LARGE before→after, screenshot evidence, quote, CTA
 */

const featured = {
  badge: "The $25M SMS Build",
  client: "The Oodie",
  clientRole: "Australia's #1 DTC Brand · $800M+ Revenue",
  founder: "Davie Fogarty",
  founderRole: "Founder",
  situation: "The Oodie had no SMS channel at all. Davie asked Jason to build SMS into their ecosystem without touching what was working in email. The brief: add a new revenue channel. Don't break the existing one.",
  before: "$0",
  after: "$25M+",
  metric: "SMS Revenue · channel built from scratch",
  timeframe: "under 2 years",
  quote: "He drove over 25 million for The Oodie with the SMS. Ton of energy, an energy uplifter rather than a drainer. I do trust him a lot — which is a big thing for agencies. Highly recommend. Give them a go.",
  lift: "From $0",
};

const cases = [
  {
    client: "OTAA",
    segment: "Accessories · 8-Figure Brand",
    before: "21%",
    after: "40%",
    metric: "Email contribution to revenue",
    timeframe: "90 days",
    quote: "e2 doubled our revenue growth to almost 40% and brought groundbreaking changes. His guidance during Black Friday led to the busiest week in our company's history.",
    author: "Fameez Haroon, Co-Founder",
  },
  {
    client: "The Littl",
    segment: "Jewellery · Direct-to-Consumer",
    before: "25%",
    after: "48%",
    metric: "EDM sales of total revenue",
    timeframe: "6 months",
    quote: "Jason managed to make our EDM sales grow from 25% to 48% of total revenue. I genuinely thought we were doing great prior to them. e2 is the 🐐.",
    author: "Alice Robert, Founder",
  },
  {
    client: "Nexus Sports Nutrition",
    segment: "Supplements · eCommerce",
    before: "15%",
    after: "50%+",
    metric: "Email open rate",
    timeframe: "4 months",
    quote: "e2 made a huge impact on our email performance. They lifted our open rates from under 15% to over 50% and turned the channel into a real growth driver.",
    author: "Adam C, Head of Marketing",
  },
];
---

<section class="py-32 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-gray-950 to-gray-950 pointer-events-none"></div>
  <!-- Ambient glows -->
  <div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-blue-600/10 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-indigo-600/10 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="section-container relative z-10">

    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center mb-16">
      <p class="text-xs font-bold uppercase tracking-widest text-blue-400 mb-4">Proof</p>
      <h2 class="font-bold text-4xl md:text-5xl mb-6 text-white tracking-tight text-balance">
        Real Numbers.<br/>
        <span class="text-gray-500">Real Brands. Real Revenue.</span>
      </h2>
      <p class="text-xl text-gray-400 leading-relaxed text-balance">
        Every result below is verified. Every number came from a Klaviyo or Shopify dashboard.
      </p>
    </div>

    <!-- Featured Case Study , Davie / The Oodie -->
    <div class="mb-12">
      <div class="rounded-[3rem] border border-white/10 bg-white/5 backdrop-blur-sm p-10 md:p-16 relative overflow-hidden">
        <!-- Inner glow -->
        <div class="absolute top-0 right-0 w-96 h-96 bg-blue-500/10 rounded-full blur-[80px] -mr-48 -mt-48 pointer-events-none"></div>

        <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
          <div>
            <div class="inline-block px-3 py-1.5 rounded-full bg-blue-500/20 border border-blue-500/30 text-blue-400 text-xs font-bold uppercase tracking-widest mb-6">
              {featured.badge}
            </div>

            <!-- Before → After -->
            <div class="flex items-center gap-4 mb-8">
              <div class="text-center">
                <div class="text-4xl font-black text-gray-500 tracking-tight">{featured.before}</div>
                <div class="text-xs text-gray-600 font-semibold uppercase tracking-wide mt-1">Before</div>
              </div>
              <div class="flex-1 flex items-center justify-center">
                <div class="w-full h-px bg-gradient-to-r from-gray-700 via-blue-500 to-gray-700"></div>
                <div class="absolute px-3 py-1 rounded-full bg-blue-500/20 border border-blue-500/30 text-blue-400 text-sm font-black whitespace-nowrap">
                  {featured.lift}
                </div>
              </div>
              <div class="text-center">
                <div class="text-4xl font-black text-white tracking-tight">{featured.after}</div>
                <div class="text-xs text-gray-400 font-semibold uppercase tracking-wide mt-1">After</div>
              </div>
            </div>

            <p class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-6">{featured.metric}</p>

            <blockquote class="text-xl text-gray-300 leading-relaxed mb-8 italic">
              "{featured.quote}"
            </blockquote>

            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-gray-700 to-gray-900 border border-white/20 flex items-center justify-center text-white text-sm font-black flex-shrink-0">D</div>
              <div>
                <div class="font-bold text-white">{featured.founder}</div>
                <div class="text-sm text-gray-400">{featured.founderRole}, {featured.client}</div>
              </div>
            </div>
          </div>

          <!-- Davie Fogarty video testimonial -->
          <div class="flex flex-col gap-4">
            <!-- Facade: thumbnail shown at load, iframe injected on hover -->
            <BunnyVideo
              libraryId="609841"
              videoId="8a35383c-c3c5-48dc-8e96-6e1d396d16e4"
              title="How We Built $25M in SMS Revenue for The Oodie"
              subtitle="Davie Fogarty · Founder, The Oodie"
              author="Davie Fogarty"
              authorRole="Founder, The Oodie ($800M+)"
            />
            <!-- Compact stats strip below video -->
            <div class="grid grid-cols-3 gap-3 text-center">
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-white">$25M+</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">SMS Revenue</div>
              </div>
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-white">$0</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">Starting point</div>
              </div>
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-white">&lt;2 yrs</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">To get there</div>
              </div>
            </div>
            <p class="text-xs text-gray-600 italic text-center">Results verified via Klaviyo &amp; Postscript dashboards</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Hero Case Study #2 — BogeyBros -->
    <div class="mb-12">
      <div class="rounded-[3rem] border border-white/10 bg-white/5 backdrop-blur-sm p-10 md:p-16 relative overflow-hidden">
        <!-- Inner glow — green/golf accent -->
        <div class="absolute top-0 right-0 w-96 h-96 bg-emerald-500/10 rounded-full blur-[80px] -mr-48 -mt-48 pointer-events-none"></div>

        <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
          <!-- Left: story + quote -->
          <div>
            <div class="inline-block px-3 py-1.5 rounded-full bg-emerald-500/20 border border-emerald-500/30 text-emerald-400 text-xs font-bold uppercase tracking-widest mb-6">
              The Email Frequency Build
            </div>

            <!-- Before → After -->
            <div class="flex items-center gap-4 mb-8">
              <div class="text-center">
                <div class="text-4xl font-black text-gray-500 tracking-tight">$100k</div>
                <div class="text-xs text-gray-600 font-semibold uppercase tracking-wide mt-1">Before</div>
              </div>
              <div class="flex-1 flex items-center justify-center">
                <div class="w-full h-px bg-gradient-to-r from-gray-700 via-emerald-500 to-gray-700"></div>
                <div class="absolute px-3 py-1 rounded-full bg-emerald-500/20 border border-emerald-500/30 text-emerald-400 text-sm font-black whitespace-nowrap">
                  +100%
                </div>
              </div>
              <div class="text-center">
                <div class="text-4xl font-black text-white tracking-tight">$200k+</div>
                <div class="text-xs text-gray-400 font-semibold uppercase tracking-wide mt-1">After</div>
              </div>
            </div>

            <p class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-6">
              Email revenue per month · &lt;90 days · email channel only
            </p>

            <blockquote class="text-xl text-gray-300 leading-relaxed mb-8 italic">
              "I'd definitely recommend e2. Jason and his whole team has been incredible — the communication is great, tons of resources pouring into our strategy. Attributed revenue is up about 100% from where we were. We went from sending 6–8 emails a month to 20+ and the results have been incredible."
            </blockquote>

            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-emerald-900 to-gray-900 border border-emerald-500/20 flex items-center justify-center text-emerald-400 text-sm font-black flex-shrink-0">R</div>
              <div>
                <div class="font-bold text-white">Ryan Rizos</div>
                <div class="text-sm text-gray-400">Co-Founder & CEO · BogeyBros</div>
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-4">
            <BunnyVideo
              libraryId="609841"
              videoId="6f0c1382-ddd8-40f8-b4d4-f7e3a684f3e0"
              title="How We Doubled BogeyBros Email Revenue in 90 Days"
              subtitle="Ryan Rizos · Co-Founder & CEO, BogeyBros"
              author="Ryan Rizos"
              authorRole="Co-Founder & CEO, BogeyBros"
            />
            <div class="grid grid-cols-3 gap-3 text-center">
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-white">$300k</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">Record month</div>
              </div>
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-white">20+</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">Emails/mo</div>
              </div>
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-emerald-400">&lt;90</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">Days</div>
              </div>
            </div>
            <p class="text-xs text-gray-600 italic text-center">Results verified via Klaviyo dashboard</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Hero Case Study #3 — Canvas Cultures -->
    <div class="mb-12">
      <div class="rounded-[3rem] border border-white/10 bg-white/5 backdrop-blur-sm p-10 md:p-16 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-96 h-96 bg-violet-500/10 rounded-full blur-[80px] -ml-48 -mt-48 pointer-events-none"></div>

        <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
          <!-- Left: story + quote -->
          <div>
            <div class="inline-block px-3 py-1.5 rounded-full bg-violet-500/20 border border-violet-500/30 text-violet-400 text-xs font-bold uppercase tracking-widest mb-6">
              The 8-Year Partnership
            </div>

            <div class="flex items-center gap-4 mb-8">
              <div class="text-center">
                <div class="text-4xl font-black text-gray-500 tracking-tight">$100k</div>
                <div class="text-xs text-gray-600 font-semibold uppercase tracking-wide mt-1">Month 1</div>
              </div>
              <div class="flex-1 flex items-center justify-center">
                <div class="w-full h-px bg-gradient-to-r from-gray-700 via-violet-500 to-gray-700"></div>
                <div class="absolute px-3 py-1 rounded-full bg-violet-500/20 border border-violet-500/30 text-violet-400 text-sm font-black whitespace-nowrap">
                  15×
                </div>
              </div>
              <div class="text-center">
                <div class="text-4xl font-black text-white tracking-tight">$1.5M</div>
                <div class="text-xs text-gray-400 font-semibold uppercase tracking-wide mt-1">Peak month</div>
              </div>
            </div>

            <p class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-6">
              Monthly revenue · 8-year partnership · 7-figure exit in 2021
            </p>

            <blockquote class="text-xl text-gray-300 leading-relaxed mb-8 italic">
              "I've been knowing Jason for about eight years. He's worked on every project I've had — from $100k a month to $1.5 million a month. I made a seven-figure exit in 2021 with the canvas brand we worked on. Whoever chooses to partner with Jason will be a smart person. I hate doing these things because I feel like I'm giving away my secret weapon."
            </blockquote>

            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-violet-900 to-gray-900 border border-violet-500/20 flex items-center justify-center text-violet-400 text-sm font-black flex-shrink-0">J</div>
              <div>
                <div class="font-bold text-white">Joshua Tatum</div>
                <div class="text-sm text-gray-400">Founder · Canvas Cultures</div>
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-4">
            <BunnyVideo
              libraryId="609841"
              videoId="8d955164-4635-4902-899a-2ab1a15bb575"
              title="Canvas Cultures: From $100k to $1.5M/Month"
              subtitle="Joshua Tatum · Founder, Canvas Cultures"
              author="Joshua Tatum"
              authorRole="Founder, Canvas Cultures"
            />
            <div class="grid grid-cols-3 gap-3 text-center">
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-violet-400">15×</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">Revenue multiple</div>
              </div>
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-white">7-fig</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">Exit 2021</div>
              </div>
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-white">8 yrs</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">Partnership</div>
              </div>
            </div>
            <p class="text-xs text-gray-600 italic text-center">Revenue growth verified across multiple brand projects</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Hero Case Study #4 — Nightbuddy (ECOMX) -->
    <div class="mb-12">
      <div class="rounded-[3rem] border border-white/10 bg-white/5 backdrop-blur-sm p-10 md:p-16 relative overflow-hidden">
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-amber-500/8 rounded-full blur-[100px] pointer-events-none"></div>

        <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
          <div>
            <div class="inline-block px-3 py-1.5 rounded-full bg-amber-500/20 border border-amber-500/30 text-amber-400 text-xs font-bold uppercase tracking-widest mb-6">
              10% to 40% in 60 Days
            </div>

            <div class="flex items-center gap-4 mb-8">
              <div class="text-center">
                <div class="text-4xl font-black text-gray-500 tracking-tight">&lt;10%</div>
                <div class="text-xs text-gray-600 font-semibold uppercase tracking-wide mt-1">Before</div>
              </div>
              <div class="flex-1 flex items-center justify-center">
                <div class="w-full h-px bg-gradient-to-r from-gray-700 via-amber-500 to-gray-700"></div>
                <div class="absolute px-3 py-1 rounded-full bg-amber-500/20 border border-amber-500/30 text-amber-400 text-sm font-black whitespace-nowrap">
                  4×
                </div>
              </div>
              <div class="text-center">
                <div class="text-4xl font-black text-white tracking-tight">40%</div>
                <div class="text-xs text-gray-400 font-semibold uppercase tracking-wide mt-1">After</div>
              </div>
            </div>

            <p class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-6">
              Email + SMS attribution · 2 months · zero conversion rate drop
            </p>

            <blockquote class="text-xl text-gray-300 leading-relaxed mb-8 italic">
              "Before Jason, our email and SMS revenue was below 10% of total revenue — we were losing a lot of money pushing traffic. Two months in, it's above 30–40%. We make way more money now. The pop-up split test meant we collect way more leads too, without hurting conversion rate at all."
            </blockquote>

            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-amber-900 to-gray-900 border border-amber-500/20 flex items-center justify-center text-amber-400 text-sm font-black flex-shrink-0">D</div>
              <div>
                <div class="font-bold text-white">David Indlekofer</div>
                <div class="text-sm text-gray-400">Owner · Nightbuddy</div>
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-4">
            <BunnyVideo
              libraryId="609841"
              videoId="e03c0f11-df01-4783-9ac8-4fc493747dd7"
              title="How Nightbuddy Went From 10% to 40% Email Revenue in 60 Days"
              subtitle="David Indlekofer · Owner, Nightbuddy"
              author="David Indlekofer"
              authorRole="Owner, Nightbuddy"
            />
            <div class="grid grid-cols-3 gap-3 text-center">
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-amber-400">4×</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">Attribution</div>
              </div>
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-white">60</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">Days</div>
              </div>
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-white">0%</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">CR drop</div>
              </div>
            </div>
            <p class="text-xs text-gray-600 italic text-center">Results verified via Klaviyo dashboard</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Hero Case Study #5 — Valley Eyewear -->
    <div class="mb-12">
      <div class="rounded-[3rem] border border-white/10 bg-white/5 backdrop-blur-sm p-10 md:p-16 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-96 h-96 bg-cyan-500/10 rounded-full blur-[80px] -mr-48 -mt-48 pointer-events-none"></div>

        <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
          <div>
            <div class="inline-block px-3 py-1.5 rounded-full bg-cyan-500/20 border border-cyan-500/30 text-cyan-400 text-xs font-bold uppercase tracking-widest mb-6">
              The Agency That Gets Your Brand
            </div>

            <div class="flex items-center gap-4 mb-8">
              <div class="text-center">
                <div class="text-4xl font-black text-gray-500 tracking-tight">22%</div>
                <div class="text-xs text-gray-600 font-semibold uppercase tracking-wide mt-1">Before</div>
              </div>
              <div class="flex-1 flex items-center justify-center">
                <div class="w-full h-px bg-gradient-to-r from-gray-700 via-cyan-500 to-gray-700"></div>
                <div class="absolute px-3 py-1 rounded-full bg-cyan-500/20 border border-cyan-500/30 text-cyan-400 text-sm font-black whitespace-nowrap">
                  +123%
                </div>
              </div>
              <div class="text-center">
                <div class="text-4xl font-black text-white tracking-tight">49%</div>
                <div class="text-xs text-gray-400 font-semibold uppercase tracking-wide mt-1">After</div>
              </div>
            </div>

            <p class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-6">
              Klaviyo attributed revenue · 12 months
            </p>

            <blockquote class="text-xl text-gray-300 leading-relaxed mb-8 italic">
              "We've seen a vast improvement in our return on investment and our Klaviyo account. We're finally with an agency that gets our brand, gets the way we speak to our customers. They say they're going to do it, they do it. Nothing but an amazing experience."
            </blockquote>

            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-cyan-900 to-gray-900 border border-cyan-500/20 flex items-center justify-center text-cyan-400 text-sm font-black flex-shrink-0">M</div>
              <div>
                <div class="font-bold text-white">Michael Crawley</div>
                <div class="text-sm text-gray-400">Director · Valley Eyewear</div>
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-4">
            <BunnyVideo
              libraryId="609841"
              videoId="c841d495-e31a-40eb-abc8-3b548bb1c0ed"
              title="How Valley Eyewear Nearly Doubled Klaviyo Revenue"
              subtitle="Michael Crawley · Director, Valley Eyewear"
              author="Michael Crawley"
              authorRole="Director, Valley Eyewear"
            />
            <div class="grid grid-cols-3 gap-3 text-center">
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-cyan-400">49%</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">Klaviyo attr.</div>
              </div>
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-white">+123%</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">Revenue lift</div>
              </div>
              <div class="rounded-xl bg-white/5 border border-white/10 p-4">
                <div class="text-2xl font-black text-white">12 mo</div>
                <div class="text-xs text-gray-500 uppercase font-semibold tracking-wide mt-1">Timeframe</div>
              </div>
            </div>
            <p class="text-xs text-gray-600 italic text-center">Results verified via Klaviyo dashboard</p>
          </div>
        </div>
      </div>
    </div>

    <!-- BFCM Hero #1: Nail Cosmetics Brand -->
    <div class="mb-16">
      <div class="flex flex-col lg:flex-row gap-0 rounded-[2.5rem] overflow-hidden border border-white/10 shadow-2xl shadow-rose-500/5">
        <div class="lg:w-[45%] bg-gradient-to-br from-gray-900 via-gray-900 to-gray-950 p-10 md:p-14 flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-3 mb-8">
              <div class="w-10 h-10 rounded-2xl bg-rose-500/15 border border-rose-500/25 flex items-center justify-center text-rose-400 text-lg">💅</div>
              <span class="text-xs font-bold uppercase tracking-widest text-rose-400">BFCM Email Strategy</span>
            </div>
            <h3 class="font-black text-white text-3xl md:text-4xl leading-none tracking-tight mb-4">
              421% YoY BFCM<br/>Email Revenue
            </h3>
            <p class="text-gray-400 text-lg leading-relaxed mb-8">
              A Nail Cosmetics brand came to us after a flat BFCM season — diluted messaging, low volume, poor deliverability. We rebuilt everything and took them from A$200k to over A$1M in email revenue in a single BFCM period.
