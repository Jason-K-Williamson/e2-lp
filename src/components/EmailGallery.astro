---
/**
 * EmailGallery , Horizontal scroll showcase of real EDM designs.
 * "Show don't tell" proof of design quality.
 */
const emails = [
    {
        src: "/EDM Designs/bruce-bolt.webp",
        brand: "Bruce Bolt",
        w: 480,
        h: 3857,
    },
    {
        src: "/EDM Designs/fleecies.webp",
        brand: "Fleecies",
        w: 478,
        h: 2634,
    },
    {
        src: "/EDM Designs/littl-swim.webp",
        brand: "Littl Swim",
        w: 458,
        h: 4109,
    },
    {
        src: "/EDM Designs/client-1.webp",
        brand: "Client",
        w: 479,
        h: 3618,
    },
    {
        src: "/EDM Designs/client-2.webp",
        brand: "Client",
        w: 378,
        h: 2096,
    },
    {
        src: "/EDM Designs/client-3.avif",
        brand: "Client",
        w: 581,
        h: 4096,
    },
    {
        src: "/EDM Designs/client-4.avif",
        brand: "Client",
        w: 527,
        h: 4096,
    },
];
---

<section class="py-24 overflow-hidden">
    <div class="section-container mb-12">
        <div class="max-w-3xl mx-auto text-center">
            <p
                class="text-sm font-bold uppercase tracking-widest text-blue-600 mb-4"
            >
                The Work
            </p>
            <h2
                class="font-bold text-4xl md:text-5xl lg:text-6xl text-e2-black tracking-tight mb-5 text-balance"
            >
                We turn brands that look like Toyota into Mercedes.
            </h2>
            <p class="text-xl text-gray-500 mb-10">
                Emails That Stop the Scroll. Not Templates. Not AI. Real Design.
            </p>
            <p class="text-base text-gray-400 max-w-xl mx-auto">
                Every email is built from scratch for your brand. Here's a
                sample of what lands in your customers' inboxes.
            </p>
        </div>
    </div>

    <!-- Horizontal scroll strip -->
    <div
        class="flex gap-6 overflow-x-auto pb-6 px-6 md:px-12 snap-x snap-mandatory scrollbar-hide"
        style="scroll-padding-left: 1.5rem;"
    >
        {
            emails.map((email) => (
                <div class="flex-shrink-0 snap-start w-[260px] md:w-[300px] group">
                    <div class="rounded-2xl overflow-hidden shadow-lg shadow-gray-200/60 border border-gray-100 bg-white hover:shadow-xl hover:shadow-gray-300/40 transition-all duration-300 hover:-translate-y-1">
                        <img
                            src={email.src}
                            alt={`${email.brand} email design by e2 Agency`}
                            class="w-full object-cover object-top"
                            style="max-height: 480px;"
                            loading="lazy"
                            width={email.w}
                            height={email.h}
                        />
                        <div class="px-4 py-3 border-t border-gray-100">
                            <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">
                                {email.brand}
                            </span>
                        </div>
                    </div>
                </div>
            ))
        }

        <!-- End card: CTA -->
        <div
            class="flex-shrink-0 snap-start w-[260px] md:w-[300px] flex items-center justify-center"
        >
            <div
                class="rounded-2xl bg-e2-black text-white p-8 text-center h-full flex flex-col items-center justify-center min-h-[300px]"
            >
                <div class="text-4xl mb-4">✉️</div>
                <p class="font-bold text-lg mb-2">Your brand.<br />Next.</p>
                <p class="text-gray-400 text-sm mb-6">
                    Every email built from scratch. No templates.
                </p>
                <a
                    href="#offer"
                    class="px-6 py-3 rounded-xl bg-white text-e2-black font-bold text-sm hover:scale-[1.02] transition-transform"
                >
                    See If You Qualify →
                </a>
            </div>
        </div>
    </div>

    <!-- Scroll hint (mobile) -->
    <p class="text-center text-xs text-gray-400 mt-4 md:hidden">
        ← Swipe to see more →
    </p>

    <!-- Figma Showcase Embed -->
    <div class="section-container mt-20">
        <div class="max-w-3xl mx-auto text-center mb-10">
            <p
                class="text-xs font-bold uppercase tracking-widest text-blue-600 mb-3"
            >
                Full Design Showcase
            </p>
            <h3
                class="font-bold text-3xl md:text-4xl text-e2-black tracking-tight mb-4"
            >
                200+ Emails. Browse Every One.
            </h3>
            <p class="text-gray-500 text-lg">
                Click and explore the exact designs we've built for clients —
                live, interactive, scrollable.
            </p>
        </div>

        <!-- Lazy-loaded Figma iframe wrapper -->
        <div
            id="figma-embed-wrapper"
            class="relative rounded-3xl overflow-hidden border border-gray-200 shadow-2xl shadow-gray-200/60 bg-gray-50"
            style="padding-top: 62.5%;"
        >
            <!-- Placeholder shown while iframe loads -->
            <div
                id="figma-placeholder"
                class="absolute inset-0 flex flex-col items-center justify-center gap-4 bg-gray-50"
            >
                <div class="w-16 h-16 rounded-2xl bg-gray-200 animate-pulse">
                </div>
                <p class="text-sm text-gray-400 font-medium animate-pulse">
                    Loading design showcase…
                </p>
            </div>

            <!-- iframe injected by IntersectionObserver -->
            <iframe
                id="figma-embed"
                data-src="https://www.figma.com/embed?embed_host=share&url=https://www.figma.com/design/ZOquuBK1IV1SWNip9akgsQ/Showcase-Emails?node-id=0-1&t=47GZRz1Isi2grklv-1"
                class="absolute inset-0 w-full h-full opacity-0 transition-opacity duration-500"
                style="border: none;"
                allowfullscreen
                title="e2 Agency — Email Design Showcase"></iframe>
        </div>

        <p class="text-center text-xs text-gray-400 mt-4">
            Interactive Figma showcase · click to explore all designs
        </p>
    </div>
</section>

<style>
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
</style>

<script>
    // Load Figma as soon as visitor reaches the case studies section —
    // it'll be fully loaded by the time they scroll down to EmailGallery.
    const iframe = document.getElementById(
        "figma-embed"
    ) as HTMLIFrameElement | null;
    const placeholder = document.getElementById("figma-placeholder");

    const loadFigma = () => {
        if (iframe && !iframe.src) {
            iframe.src = iframe.dataset.src ?? "";
            iframe.onload = () => {
                iframe.classList.remove("opacity-0");
                placeholder?.classList.add("hidden");
            };
        }
    };

    // Trigger: MajorCaseStudies section enters viewport (fires one section early)
    const trigger =
        document.getElementById("major-case-studies") ??
        document.getElementById("problem-section");
    if (trigger && iframe) {
        new IntersectionObserver(
            (entries, obs) => {
                if (entries[0].isIntersecting) {
                    loadFigma();
                    obs.disconnect();
                }
            },
            { rootMargin: "200px" }
        ).observe(trigger);
    } else {
        // Fallback: load when the embed wrapper itself is near
        const wrapper = document.getElementById("figma-embed-wrapper");
        if (wrapper) {
            new IntersectionObserver(
                (entries, obs) => {
                    if (entries[0].isIntersecting) {
                        loadFigma();
                        obs.disconnect();
                    }
                },
                { rootMargin: "400px" }
            ).observe(wrapper);
        }
    }
</script>
